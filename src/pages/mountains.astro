---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { journeys, pastExpeditions } from '../data/mountains';
import '../styles/global.css';

const upcomingJourneys = journeys.filter(j => j.status === 'upcoming');
const soonJourneys     = journeys.filter(j => j.status === 'soon');

const calendar = [
  ...upcomingJourneys.map(j => ({
    month: j.dateShort.split(' ')[0],
    name: j.title,
    location: j.location.split(',')[0],
    status: 'open' as const,
    slug: j.slug,
  })),
  ...soonJourneys.map(j => ({
    month: '—',
    name: j.title,
    location: j.location.split(',')[0],
    status: 'soon' as const,
    slug: null as null,
  })),
];

const past = pastExpeditions;

const featuredJourney = upcomingJourneys[0];

const reviews = [
  { quote: '[Review to be added after the expedition. A personal account of the experience.]', name: 'Name Surname', detail: 'Country · Year' },
  { quote: '[Review to be added after the expedition. A personal account of the experience.]', name: 'Name Surname', detail: 'Country · Year' },
  { quote: '[Review to be added after the expedition. A personal account of the experience.]', name: 'Name Surname', detail: 'Country · Year' },
];
---

<Base
  title="Mountains — The Open Sky"
  description="Expeditions to sacred mountains. Kailash. Arunachala. Annapurna. Journeys to places of power and inner transformation, led by Yakov Rajuna."
>
  <Nav />
  <main>

    <!-- ══════════════════════════════════════════
         1. MOUNTAINS HERO
         ══════════════════════════════════════════ -->

    <section class="mhero" aria-label="Mountains">
      <div class="mhero__overlay" aria-hidden="true"></div>
      <div class="mhero__img" aria-hidden="true">
        <!-- Replace with: <img src="/images/mountains-hero.jpg" alt="" class="mhero__photo" /> -->
      </div>
      <div class="mhero__content frame">
        <span class="mhero__overline t-label reveal">The Open Sky</span>
        <h1 class="mhero__title reveal d1">Mountains</h1>
        <p class="mhero__sub reveal d2">
          Journeys to sacred mountains,<br />places of power and inner transformation.
        </p>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         2. UPCOMING EXPEDITION — FEATURED
         ══════════════════════════════════════════ -->

    {featuredJourney && (
    <section class="mfeat section" aria-label="Upcoming expedition">
      <div class="frame">

        <div class="mfeat__header reveal">
          <span class="t-label mfeat__label">Upcoming Expedition</span>
        </div>

        <div class="mfeat__block">
          <div class="mfeat__image reveal">
            <div class="mfeat__img-placeholder" aria-hidden="true" style={`background: ${featuredJourney.bg};`}>
              <span class="mfeat__img-label">{featuredJourney.title} · {featuredJourney.terrain}</span>
            </div>
            <div class="mfeat__img-badge reveal d2">
              <span class="mfeat__img-badge-status">Applications Open</span>
            </div>
          </div>

          <div class="mfeat__info">
            <div class="mfeat__meta reveal">
              <span class="mfeat__location">{featuredJourney.terrain}</span>
              <span class="mfeat__dot" aria-hidden="true">·</span>
              <span class="mfeat__date">{featuredJourney.dateShort}</span>
              {featuredJourney.duration && <>
                <span class="mfeat__dot" aria-hidden="true">·</span>
                <span class="mfeat__duration">{featuredJourney.duration}</span>
              </>}
            </div>

            <h2 class="mfeat__title reveal d1">{featuredJourney.title}</h2>

            <p class="mfeat__teaser reveal d3">
              {featuredJourney.description}
            </p>

            <div class="mfeat__details reveal d3">
              <div class="mfeat__detail-row">
                <span class="mfeat__detail-label">Departure</span>
                <span class="mfeat__detail-val">{featuredJourney.date}</span>
              </div>
              <div class="mfeat__detail-row">
                <span class="mfeat__detail-label">Duration</span>
                <span class="mfeat__detail-val">{featuredJourney.duration}</span>
              </div>
              {featuredJourney.altitude && (
                <div class="mfeat__detail-row">
                  <span class="mfeat__detail-label">Altitude</span>
                  <span class="mfeat__detail-val">{featuredJourney.altitude}</span>
                </div>
              )}
              {featuredJourney.groupSize && (
                <div class="mfeat__detail-row">
                  <span class="mfeat__detail-label">Group</span>
                  <span class="mfeat__detail-val">{featuredJourney.groupSize}</span>
                </div>
              )}
            </div>

            <div class="mfeat__actions reveal d4">
              <a href={`/mountains/${featuredJourney.slug}`} class="btn mfeat__btn-primary">Explore Journey</a>
              <a href="/connect" class="btn btn--outline mfeat__btn-secondary">Apply</a>
            </div>
          </div>
        </div>

      </div>
    </section>
    )}

    <!-- ══════════════════════════════════════════
         3. EXPEDITION CALENDAR
         ══════════════════════════════════════════ -->

    <section class="mcal section" aria-label="Expedition calendar">
      <div class="frame">

        <div class="mcal__header reveal">
          <span class="t-label mcal__label">2026 Expeditions</span>
          <h2 class="mcal__heading">Where we go next.</h2>
        </div>

        <div class="mcal__table" role="list">
          {calendar.map((exp, i) => (
            <div class={`mcal__row reveal d${(i % 3) + 1}`} role="listitem">
              <span class="mcal__month">{exp.month}</span>
              <div class="mcal__info">
                <span class="mcal__name">{exp.name}</span>
                <span class="mcal__loc">{exp.location}</span>
              </div>
              <div class="mcal__right">
                <span class={`mcal__status mcal__status--${exp.status}`}>
                  {exp.status === 'open' ? 'Open' : 'Coming Soon'}
                </span>
                {exp.slug
                  ? <a href={`/mountains/${exp.slug}`} class="btn-text mcal__link">View</a>
                  : <span class="mcal__tba">Dates TBA</span>
                }
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         4. PAST EXPEDITIONS
         ══════════════════════════════════════════ -->

    <section class="mpast section" aria-label="Past expeditions">
      <div class="frame">

        <div class="mpast__header reveal">
          <span class="t-label mpast__label">Past Expeditions</span>
          <h2 class="mpast__heading">Where we have been.</h2>
        </div>

        <div class="mpast__grid">
          {past.map((exp, i) => (
            <article class={`mpast__card reveal d${(i % 3) + 1}`}>
              <div class="mpast__card-img" style={`background: ${exp.bg};`} aria-hidden="true">
                <span class="mpast__card-region">{exp.region}</span>
                <div class="mpast__card-video">
                  <span class="mpast__play" aria-hidden="true">▷</span>
                  <span>Video · coming soon</span>
                </div>
              </div>
              <div class="mpast__card-body">
                <h3 class="mpast__card-name">{exp.name}</h3>
                <p class="mpast__card-summary">{exp.summary}</p>
                <div class="mpast__card-footer">
                  <span class="mpast__card-reviews">Reviews · coming soon</span>
                  <a href="/connect" class="btn-text mpast__card-cta">See Experience</a>
                </div>
              </div>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         5. REVIEWS
         ══════════════════════════════════════════ -->

    <section class="mrev section" aria-label="Reviews">
      <div class="frame">

        <div class="mrev__header reveal">
          <span class="t-label mrev__label">From Participants</span>
          <h2 class="mrev__heading">What people carry back.</h2>
        </div>

        <div class="mrev__grid">
          {reviews.map((r, i) => (
            <div class={`mrev__item reveal d${i + 1}`}>
              <blockquote class="mrev__quote">
                <p class="mrev__quote-text">{r.quote}</p>
                <footer class="mrev__quote-footer">
                  <cite class="mrev__cite">
                    <span class="mrev__cite-name">{r.name}</span>
                    <span class="mrev__cite-detail">{r.detail}</span>
                  </cite>
                </footer>
              </blockquote>
              <div class="mrev__video-slot" aria-hidden="true">
                <span class="mrev__video-icon">▷</span>
                <span class="mrev__video-label">Video testimonial · coming soon</span>
              </div>
            </div>
          ))}
        </div>

      </div>
      <div class="mrev__bg" aria-hidden="true"></div>
    </section>

    <!-- ══════════════════════════════════════════
         6. APPLICATION CTA
         ══════════════════════════════════════════ -->

    <section class="mcta section" aria-label="Join the journey">
      <div class="frame">
        <div class="mcta__inner reveal">
          <span class="t-label mcta__label">Expeditions</span>
          <h2 class="mcta__title">Join The Journey</h2>
          <p class="mcta__body">
            Expeditions are announced to the community first.<br />
            Applications are reviewed personally by Yakov Rajuna.
          </p>
          <div class="mcta__actions">
            <a href="/connect"              class="btn mcta__btn-apply">Apply</a>
            <a href="https://t.me/yakovrajuna" class="btn btn--ghost-d">Telegram</a>
            <a href="/connect"              class="btn btn--ghost-d">Contact</a>
          </div>
        </div>
      </div>
      <div class="mcta__bg" aria-hidden="true"></div>
    </section>

  </main>
  <Footer />
</Base>

<style>

  /* ─── Nav override — white over dark hero ─── */
  :global(.nav:not(.nav--scrolled) .nav__wordmark) {
    color: rgba(230, 242, 255, 0.28);
    text-shadow: none;
    pointer-events: none;
  }
  :global(.nav:not(.nav--scrolled) .nav__link) {
    color: rgba(215, 232, 248, 0.90);
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.45);
  }
  :global(.nav:not(.nav--scrolled) .nav__link:hover) { color: #fff; }
  :global(.nav:not(.nav--scrolled) .nav__link--connect) {
    color: rgba(215, 232, 248, 0.90);
    border-color: rgba(215, 232, 248, 0.26);
  }
  :global(.nav:not(.nav--scrolled) .nav__social) {
    color: rgba(190, 218, 242, 0.52);
    text-shadow: none;
  }
  :global(.nav:not(.nav--scrolled) .nav__social:hover) { color: #fff; opacity: 1; }
  :global(.nav:not(.nav--scrolled) .nav__burger span) { background: rgba(215, 232, 248, 0.86); }

  /* ─── Local palette ─────────────────────────── */
  :root {
    --mtn-deep:   #0B1825;
    --mtn-navy:   #112035;
    --mtn-slate:  #1E3A58;
    --mtn-silver: #7A9EBA;
    --mtn-ice:    #E8F2F8;
    --mtn-snow:   #F4F9FC;
    --mtn-gold:   #C8A85A;
    --mtn-gold-d: rgba(200, 168, 90, 0.65);
  }

  /* ══════════════════════════════════════════════
     1. HERO
     ══════════════════════════════════════════════ */

  .mhero {
    position: relative;
    min-height: 88svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .mhero__img {
    position: absolute; inset: 0; z-index: 0;
    background:
      radial-gradient(ellipse 65% 55% at 15% 28%, rgba(80, 130, 190, 0.45) 0%, transparent 62%),
      radial-gradient(ellipse 55% 45% at 82% 18%, rgba(160, 210, 240, 0.32) 0%, transparent 55%),
      linear-gradient(172deg, #1A3250 0%, #0E1E32 38%, #081018 70%, #060C14 100%);
    /* Replace contents with: <img src="/images/mountains-hero.jpg" alt="" style="width:100%;height:100%;object-fit:cover;" /> */
  }

  .mhero__overlay {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(to bottom,
        rgba(8, 14, 22, 0.48) 0%,
        rgba(8, 14, 22, 0.08) 28%,
        transparent 50%,
        rgba(6, 10, 16, 0.64) 78%,
        rgba(4, 8, 12, 0.90) 100%
      );
  }

  .mhero__content {
    position: relative; z-index: 2;
    padding-bottom: clamp(72px, 12svh, 140px);
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
  }

  .mhero__overline {
    color: rgba(160, 205, 238, 0.55);
    letter-spacing: 0.28em;
  }

  .mhero__title {
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(80px, 14vw, 200px);
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: rgba(238, 248, 255, 0.97);
    margin: 0;
    font-optical-sizing: auto;
  }

  .mhero__sub {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(16px, 1.6vw, 22px);
    line-height: 1.65;
    color: rgba(190, 220, 242, 0.68);
    margin: 0;
    max-width: 42ch;
    font-optical-sizing: auto;
  }

  /* ══════════════════════════════════════════════
     2. FEATURED EXPEDITION — KAILASH
     ══════════════════════════════════════════════ */

  .mfeat {
    background: var(--mtn-snow);
  }

  .mfeat__header {
    margin-bottom: var(--s-7);
  }

  .mfeat__label {
    color: var(--mtn-silver);
    letter-spacing: 0.26em;
  }

  /* Two-column feature block — image left, content right */
  .mfeat__block {
    display: grid;
    grid-template-columns: 1fr 480px;
    gap: clamp(40px, 6vw, 80px);
    align-items: start;
  }

  /* Image column */
  .mfeat__image {
    position: relative;
  }

  .mfeat__img-placeholder {
    aspect-ratio: 3/4;
    border-radius: var(--r-3);
    overflow: hidden;
    background:
      radial-gradient(ellipse 70% 55% at 30% 20%, rgba(100, 160, 220, 0.50) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 75% 75%, rgba(20, 50, 90, 0.60) 0%, transparent 55%),
      linear-gradient(160deg, #A8C0D8 0%, #4A6888 45%, #1A2C40 100%);
    position: relative;
  }

  .mfeat__img-label {
    position: absolute; left: 16px; bottom: 14px;
    font-family: ui-monospace, monospace;
    font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(185, 218, 245, 0.42);
  }

  .mfeat__img-badge {
    position: absolute;
    top: 20px; left: 20px;
    background: rgba(255, 255, 255, 0.96);
    border-radius: var(--r-pill);
    padding: 8px 18px;
    backdrop-filter: blur(6px);
  }

  .mfeat__img-badge-status {
    font-family: var(--mark);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: #1A3A58;
  }

  /* Info column */
  .mfeat__info {
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    padding-top: var(--s-4);
  }

  .mfeat__meta {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    flex-wrap: wrap;
  }

  .mfeat__location,
  .mfeat__date,
  .mfeat__duration {
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: var(--mtn-silver);
  }

  .mfeat__dot {
    color: rgba(122, 158, 186, 0.40);
    font-size: 10px;
  }

  .mfeat__title {
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(52px, 7vw, 100px);
    line-height: 0.90;
    letter-spacing: -0.035em;
    color: var(--mtn-deep);
    margin: 0;
    font-optical-sizing: auto;
  }

  .mfeat__subtitle {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(16px, 1.5vw, 22px);
    color: var(--mtn-silver);
    margin: 0;
    letter-spacing: 0.01em;
    font-optical-sizing: auto;
  }

  .mfeat__teaser {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 16px;
    line-height: 1.85;
    color: rgba(17, 32, 53, 0.62);
    margin: 0;
    max-width: 46ch;
  }

  /* Detail rows */
  .mfeat__details {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgba(30, 58, 88, 0.10);
    border-bottom: 1px solid rgba(30, 58, 88, 0.10);
    padding: var(--s-2) 0;
  }

  .mfeat__detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--s-3) 0;
    border-bottom: 1px solid rgba(30, 58, 88, 0.06);
  }
  .mfeat__detail-row:last-child { border-bottom: none; }

  .mfeat__detail-label {
    font-family: var(--mark);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: rgba(122, 158, 186, 0.70);
  }

  .mfeat__detail-val {
    font-family: var(--serif);
    font-style: italic;
    font-size: 15px;
    color: var(--mtn-deep);
    font-optical-sizing: auto;
  }

  /* CTA buttons */
  .mfeat__actions {
    display: flex;
    gap: var(--s-3);
    flex-wrap: wrap;
    margin-top: var(--s-2);
  }

  .mfeat__btn-primary {
    background: var(--mtn-deep);
    border-color: var(--mtn-deep);
    color: var(--mtn-ice);
  }
  .mfeat__btn-primary:hover {
    background: var(--mtn-slate);
    border-color: var(--mtn-slate);
  }

  .mfeat__btn-secondary {
    color: var(--mtn-deep);
    border-color: rgba(17, 32, 53, 0.30);
  }
  .mfeat__btn-secondary:hover {
    background: var(--mtn-deep);
    border-color: var(--mtn-deep);
    color: var(--mtn-ice);
  }

  /* ══════════════════════════════════════════════
     3. EXPEDITION CALENDAR
     ══════════════════════════════════════════════ */

  .mcal {
    background:
      radial-gradient(ellipse 80% 55% at 10% 0%, rgba(100, 160, 220, 0.18) 0%, transparent 60%),
      linear-gradient(180deg, #EAF2F8 0%, #DDE8F0 100%);
  }

  .mcal__header {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    margin-bottom: var(--s-8);
  }

  .mcal__label {
    color: var(--mtn-silver);
    letter-spacing: 0.24em;
  }

  .mcal__heading {
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(28px, 3.5vw, 52px);
    letter-spacing: -0.025em;
    color: var(--mtn-deep);
    margin: 0;
    font-optical-sizing: auto;
  }

  .mcal__table {
    display: flex;
    flex-direction: column;
  }

  .mcal__row {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    align-items: center;
    gap: var(--s-5);
    padding: var(--s-6) 0;
    border-bottom: 1px solid rgba(30, 58, 88, 0.10);
    transition: background 280ms;
  }
  .mcal__row:first-child { border-top: 1px solid rgba(30, 58, 88, 0.10); }

  .mcal__month {
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(122, 158, 186, 0.65);
    flex-shrink: 0;
  }

  .mcal__info {
    display: flex;
    align-items: baseline;
    gap: var(--s-4);
  }

  .mcal__name {
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(22px, 2.5vw, 36px);
    letter-spacing: -0.02em;
    color: var(--mtn-deep);
    font-optical-sizing: auto;
  }

  .mcal__loc {
    font-family: var(--serif);
    font-style: italic;
    font-size: 15px;
    color: rgba(30, 58, 88, 0.45);
    font-optical-sizing: auto;
  }

  .mcal__right {
    display: flex;
    align-items: center;
    gap: var(--s-5);
    flex-shrink: 0;
  }

  .mcal__status {
    font-family: var(--mark);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: var(--r-pill);
  }

  .mcal__status--open {
    color: #1A3A58;
    background: rgba(100, 165, 220, 0.18);
    border: 1px solid rgba(100, 165, 220, 0.28);
  }

  .mcal__status--soon {
    color: rgba(122, 158, 186, 0.65);
    background: rgba(122, 158, 186, 0.08);
    border: 1px solid rgba(122, 158, 186, 0.16);
  }

  .mcal__link {
    color: var(--mtn-deep);
  }
  .mcal__link::after { background: var(--mtn-deep); }

  .mcal__tba {
    font-family: var(--mark);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(122, 158, 186, 0.40);
  }

  /* ══════════════════════════════════════════════
     4. PAST EXPEDITIONS
     ══════════════════════════════════════════════ */

  .mpast {
    background: var(--mtn-snow);
  }

  .mpast__header {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    margin-bottom: var(--s-8);
  }

  .mpast__label {
    color: var(--mtn-silver);
    letter-spacing: 0.24em;
  }

  .mpast__heading {
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(28px, 3.5vw, 52px);
    letter-spacing: -0.025em;
    color: var(--mtn-deep);
    margin: 0;
    font-optical-sizing: auto;
  }

  .mpast__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--s-5);
  }

  .mpast__card {
    display: flex;
    flex-direction: column;
    border-radius: var(--r-3);
    overflow: hidden;
    border: 1px solid rgba(30, 58, 88, 0.10);
    background: #fff;
    transition: transform 400ms var(--ease), box-shadow 400ms var(--ease);
  }
  .mpast__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 24px 48px -24px rgba(17, 32, 53, 0.16);
  }

  .mpast__card-img {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
