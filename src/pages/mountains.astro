---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const upcoming = [
  {
    slug: 'kailash-2026',
    name: 'Kailash',
    terrain: 'Tibet',
    date: 'September 20',
    duration: '10 Days',
    status: 'open' as const,
    bg: 'linear-gradient(160deg, #A8C0D8 0%, #4A6888 45%, #1A2C40 100%)',
  },
  {
    slug: 'arunachala-2026',
    name: 'Arunachala',
    terrain: 'India',
    date: 'November',
    duration: '7 Days',
    status: 'open' as const,
    bg: 'linear-gradient(160deg, #D4A87A 0%, #8C5A3A 50%, #3A1E12 100%)',
  },
  {
    slug: null as string | null,
    name: 'Annapurna',
    terrain: 'Nepal',
    date: 'May 2027',
    duration: 'TBA',
    status: 'soon' as const,
    bg: 'linear-gradient(160deg, #B8C8D0 0%, #6080A0 45%, #1E3048 100%)',
  },
];

const past = [
  {
    name: 'Mardi Himal',
    terrain: 'Nepal',
    year: '2025',
    participants: '12 participants',
    bg: 'linear-gradient(160deg, #7898B8 0%, #3A5878 50%, #18283A 100%)',
  },
  {
    name: 'Himalayas',
    terrain: 'India',
    year: '2024',
    participants: null as string | null,
    bg: 'linear-gradient(160deg, #A0B4C8 0%, #506880 50%, #1E2C3A 100%)',
  },
];

const testimonials = [
  {
    quote: 'I returned quieter. More certain of what matters. The mountain doesn\'t explain itself — and neither does the change.',
    name: 'Elena K.',
    location: 'Moscow',
    journey: 'Mardi Himal 2025',
  },
  {
    quote: 'Yakov holds the space without filling it. That quality is rare. The mountains do the work — he ensures you can receive it.',
    name: 'David M.',
    location: 'Berlin',
    journey: 'Georgian Highlands 2024',
  },
  {
    quote: 'Not transformed in any dramatic way — clarified. Like something blurry for years finally came into focus.',
    name: 'Maria T.',
    location: 'Tbilisi',
    journey: 'Pontic Alps 2024',
  },
];

const openJourney = upcoming.find(j => j.status === 'open' && j.slug != null) ?? null;
---

<Base
  title="Path of the Spirit — The Open Sky"
  description="Sacred journeys to places of power. Pilgrimages to Kailash, Arunachala, Annapurna and beyond. Led by Yakov Rajuna."
>
  <Nav />
  <main class="pts">

    <!-- ══════════════════════════════════════════
         01. HERO
         ══════════════════════════════════════════ -->

    <section class="pts-hero" aria-label="Path of the Spirit">
      <img
        class="pts-hero__bg"
        src="/images/mountains/hero.jpg"
        alt=""
        aria-hidden="true"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div class="pts-hero__overlay" aria-hidden="true"></div>
      <div class="pts-hero__inner frame">
        <div class="pts-hero__left">
          <div class="pts-hero__hed">
            <h1 class="pts-hero__title reveal d1">Path of the Spirit</h1>
            <p class="pts-hero__byline reveal d2">by Yakov Rajuna</p>
          </div>
          <a href="#schedule" class="pts-hero__btn reveal d3">Explore Journeys</a>
        </div>

        {openJourney && (
          <div class="pts-hero__right">
            <div class="pts-hero__card reveal d3">
              <div class="pts-hero__card-photo">
                <img
                  src="/images/mountains/kailash-featured.jpg"
                  alt="Mount Kailash, Tibet — sacred pilgrimage destination"
                  loading="eager"
                  decoding="async"
                />
                <div class="pts-hero__card-photo-fade" aria-hidden="true"></div>
                <div class="pts-hero__card-badge">
                  <span class="pts-hero__card-badge-dot">●</span>
                  <span>4 places remaining</span>
                </div>
              </div>

              <div class="pts-hero__card-body">
                <span class="pts-hero__card-terrain">Tibet · 6,638m · 10 Days</span>
                <h2 class="pts-hero__card-title">{openJourney.name}</h2>
                <p class="pts-hero__card-tagline">The Abode of Shiva</p>
                <div class="pts-hero__card-meta">
                  <span>September 20–30</span>
                  <span class="pts-hero__card-dot">·</span>
                  <span>Max 6 people</span>
                </div>
                <div class="pts-hero__card-divider"></div>
                <div class="pts-hero__card-actions">
                  <a href={`/mountains/${openJourney.slug!}`} class="pts-btn pts-btn--gold">View Journey</a>
                  <a href="/connect?source=mountains_hub_kailash_apply" class="pts-btn pts-btn--ghost">Apply Now</a>
                </div>
              </div>
            </div>
          </div>
        )}
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         03. КТО ВЕДЁТ
         ══════════════════════════════════════════ -->

    <section class="pts-guide section" aria-label="About the guide">
      <div class="frame">
        <div class="pts-guide__body">

          <div class="pts-guide__photo reveal">
            <div class="pts-guide__photo-img" role="img" aria-label="Yakov Rajuna"></div>
          </div>

          <div class="pts-guide__content">
            <span class="pts-guide__label t-label t-label--gold reveal">Your guide</span>
            <h2 class="pts-guide__name reveal d1">Yakov Rajuna</h2>

            <div class="pts-guide__stats reveal d2">
              <div class="pts-guide__stat">
                <span class="pts-guide__stat-n">20+</span>
                <span class="pts-guide__stat-l">Years of practice</span>
              </div>
              <div class="pts-guide__stat">
                <span class="pts-guide__stat-n">350+</span>
                <span class="pts-guide__stat-l">Ceremonies led</span>
              </div>
              <div class="pts-guide__stat">
                <span class="pts-guide__stat-n">3 500+</span>
                <span class="pts-guide__stat-l">Participants</span>
              </div>
            </div>

            <p class="pts-guide__roles reveal d2">
              Guide · Healer · Teacher · Musician · Expedition leader
            </p>

            <p class="pts-guide__bio reveal d3">
              Yakov has led groups into sacred terrain across Asia, the Caucasus and
              Eastern Europe for two decades. Initiations in Peru and Brazil.
              Each expedition is small, intentional, and led personally.
            </p>

            <a href="/about" class="pts-btn pts-btn--ghost-sm reveal d4">Learn More</a>
          </div>

        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         04. ОТЗЫВЫ УЧАСТНИКОВ
         ══════════════════════════════════════════ -->

    <section class="pts-tst section" aria-label="Participant voices">
      <div class="frame">

        <div class="pts-tst__grid">
          {testimonials.map((t, i) => (
            <figure class={`pts-tst__card reveal d${i + 1}`}>
              <span class="pts-tst__glyph" aria-hidden="true">"</span>
              <blockquote class="pts-tst__quote">{t.quote}</blockquote>
              <figcaption class="pts-tst__attr">
                <span class="pts-tst__name">{t.name}</span>
                <span class="pts-tst__meta">{t.location} · {t.journey}</span>
              </figcaption>
            </figure>
          ))}
        </div>

      </div>
    </section>


    <!-- ══════════════════════════════════════════
         05. DIVIDER — СУТЬ ФОРМАТА
         ══════════════════════════════════════════ -->

    <div class="pts-divider-phrase">
      <div class="frame">
        <p class="pts-divider-phrase__text reveal">
          This is not tourism. It is an encounter with places that have shaped
          the inner life of humanity for centuries.
        </p>
      </div>
    </div>


    <!-- ══════════════════════════════════════════
         04. РАСПИСАНИЕ — ВСЕ ВЫЕЗДЫ
         ══════════════════════════════════════════ -->

    <section class="pts-schedule section" id="schedule" aria-label="Upcoming expeditions">
      <div class="frame">

        <h2 class="pts-section-title reveal">Where we go next.</h2>

        <div class="pts-cards">
          {upcoming.map((j, i) => (
            <div class={`pts-card reveal d${(i % 3) + 1}${j.status === 'soon' ? ' pts-card--soon' : ''}`}>
              <div class="pts-card__img" style={`background: ${j.bg};`} role="img" aria-label={j.name}>
                {j.status === 'soon' && <span class="pts-card__badge">Coming Soon</span>}
              </div>
              <div class="pts-card__info">
                {j.terrain && <span class="pts-card__region">{j.terrain}</span>}
                <h3 class="pts-card__name">{j.name}</h3>
                {j.date && (
                  <p class="pts-card__meta">
                    {j.date}{j.duration && j.duration !== 'TBA' ? ` · ${j.duration}` : ''}
                  </p>
                )}
                {j.slug && (
                  <a href={`/mountains/${j.slug}`} class="pts-card__link">
                    Learn More
                    <span class="pts-card__link-line" aria-hidden="true"></span>
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>


    <!-- ══════════════════════════════════════════
         06. ПРОШЛЫЕ ЭКСПЕДИЦИИ
         ══════════════════════════════════════════ -->

    <section class="pts-past section" aria-label="Past expeditions">
      <div class="frame">

        <div class="pts-past__header reveal">
          <p class="pts-past__label t-label t-label--gold">Past Expeditions</p>
          <h2 class="pts-past__title">Where we have been.</h2>
        </div>

        <div class="pts-past-cards">
          {past.map((p, i) => (
            <div class={`pts-past-card reveal d${i + 1}`}>
              <div class="pts-past-card__img" style={`background: ${p.bg};`} role="img" aria-label={p.name}></div>
              <div class="pts-past-card__info">
                <span class="pts-past-card__region">{p.terrain}</span>
                <h3 class="pts-past-card__name">{p.name}</h3>
                <p class="pts-past-card__meta">
                  {p.year}{p.participants ? ` · ${p.participants}` : ''}
                </p>
                <a href={`/connect?source=mountains_hub_past_${i + 1}`} class="pts-card__link">
                  Photos &amp; Stories
                  <span class="pts-card__link-line" aria-hidden="true"></span>
                </a>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>


    <!-- ══════════════════════════════════════════
         08. ФИНАЛЬНЫЙ CTA
         ══════════════════════════════════════════ -->

    <section class="pts-final-cta section" aria-label="Apply">
      <div class="frame">
        <div class="pts-final-cta__inner">

          <div class="pts-final-cta__text">
            <p class="t-label t-label--gold reveal">Ready to go</p>
            <h2 class="pts-final-cta__title reveal d1">
              Max 6 people.<br />
              <em>Each journey led personally.</em>
            </h2>
            <p class="pts-final-cta__sub reveal d2">
              Places fill months before departure. Write now —
              Yakov reads every message himself.
            </p>
          </div>

          <div class="pts-final-cta__actions reveal d2">
            {openJourney ? (
              <a href={`/mountains/${openJourney.slug!}`} class="pts-btn pts-btn--gold">
                View {openJourney.name}
              </a>
            ) : (
              <a
                href="https://t.me/yakovrajuna"
                class="pts-btn pts-btn--gold"
                target="_blank"
                rel="noopener noreferrer"
              >
                Join Telegram
              </a>
            )}
            <a href="/connect?source=mountains_hub_footer" class="pts-btn pts-btn--ghost">Write directly</a>
          </div>

        </div>
      </div>
    </section>

  </main>
  <Footer />
</Base>

<style>

  /* ─── PALETTE ─────────────────────────────────────── */

  .pts {
    --deep:       #080E18;
    --navy:       #0D1929;
    --mid:        #14243A;
    --silver:     #6A8099;
    --sky:        #C8DCF0;
    --sky-rgb:    200 220 240;
    --gold:       #C4A862;
    --gold-hover: #B8983A;
    --bone:       #F0EBE0;
  }

  /* ─── SHARED BUTTONS ──────────────────────────────── */

  .pts-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    padding: 16px 32px;
    border-radius: var(--r-pill);
    border: 1px solid transparent;
    transition:
      background-color 350ms var(--ease),
      border-color 350ms var(--ease),
      color 350ms var(--ease),
      transform 350ms var(--ease);
    white-space: nowrap;
    cursor: pointer;
  }

  .pts-btn--gold {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--deep);
  }
  .pts-btn--gold:hover {
    background: var(--gold-hover);
    border-color: var(--gold-hover);
    transform: translateY(-1px);
  }

  .pts-btn--ghost {
    background: transparent;
    border-color: rgba(200,220,240,0.28);
    color: rgba(200,220,240,0.80);
  }
  .pts-btn--ghost:hover {
    border-color: rgba(200,220,240,0.55);
    color: var(--bone);
    transform: translateY(-1px);
  }

  .pts-btn--ghost-sm {
    background: transparent;
    border-color: rgba(200,220,240,0.25);
    color: rgba(200,220,240,0.65);
    padding: 13px 26px;
    font-size: 10px;
    font-family: var(--mark);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border-radius: var(--r-pill);
    display: inline-flex;
    transition: all 350ms var(--ease);
  }
  .pts-btn--ghost-sm:hover {
    border-color: rgba(200,220,240,0.50);
    color: var(--bone);
    transform: translateY(-1px);
  }


  /* ══════════════════════════════════════════════════
     01. HERO
     ══════════════════════════════════════════════════ */

  .pts-hero {
    position: relative;
    height: 100svh;
    min-height: 640px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .pts-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 36%;
    display: block;
    /* Cold altitude: slightly desaturated + lifted contrast */
    filter: contrast(1.08) saturate(0.80) brightness(0.92);
    transform-origin: 50% 36%;
    will-change: transform;
    animation: ptsHeroFloat 20s ease-in-out infinite alternate;
  }

  @keyframes ptsHeroFloat {
    from { transform: scale(1.00); }
    to   { transform: scale(1.05) translateY(-8px); }
  }

  .pts-hero__overlay {
    position: absolute;
    inset: 0;
    background:
      /* Cold atmosphere at peaks — very subtle blue-black top haze */
      linear-gradient(to bottom,
        rgba(6,10,20,0.45) 0%,
        rgba(6,10,20,0.14) 18%,
        transparent 42%
      ),
      /* Bottom anchor — strong dark ground for text legibility */
      linear-gradient(to top,
        rgba(4,7,14,0.98) 0%,
        rgba(4,7,14,0.85) 18%,
        rgba(4,7,14,0.55) 36%,
        rgba(4,7,14,0.22) 54%,
        rgba(4,7,14,0.06) 68%,
        transparent 82%
      ),
      /* Left panel — softens left edge for text */
      linear-gradient(105deg,
        rgba(6,10,20,0.60) 0%,
        rgba(6,10,20,0.24) 28%,
        transparent 52%
      ),
      /* Right edge — atmospheric depth */
      linear-gradient(to left,
        rgba(6,10,20,0.28) 0%,
        transparent 34%
      ),
      /* Altitude vignette — darkens perimeter subtly */
      radial-gradient(ellipse 90% 80% at 50% 42%,
        transparent 45%,
        rgba(4,7,14,0.30) 100%
      );
  }

  .pts-hero__inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 360px;
    align-items: center;
    gap: 40px;
    width: 100%;
    padding-right: clamp(24px, 4vw, 60px);
    padding-bottom: clamp(60px, 10svh, 120px);
  }

  .pts-hero__left {
    display: flex;
    flex-direction: column;
    gap: var(--s-7);
  }

  .pts-hero__hed {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }

  .pts-hero__title {
    font-family: var(--display);
    font-weight: 300;
    /* Slightly pulled back — landscape stays primary */
    font-size: clamp(48px, 8vw, 110px);
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: var(--bone);
    margin: 0;
    font-optical-sizing: auto;
    text-wrap: balance;
    /* Subtle text shadow for depth against mountain */
    text-shadow: 0 2px 40px rgba(4,7,14,0.55);
  }

  .pts-hero__byline {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(14px, 1.2vw, 17px);
    color: rgba(196,168,98,0.65);
    margin: 0;
    letter-spacing: 0.03em;
    font-optical-sizing: auto;
  }

  .pts-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    padding: 16px clamp(28px, 4vw, 48px);
    border-radius: var(--r-pill);
    border: 1px solid rgba(200,220,240,0.20);
    color: rgba(200,220,240,0.75);
    background: transparent;
    transition: all 350ms var(--ease);
  }
  .pts-hero__btn:hover {
    border-color: rgba(200,220,240,0.50);
    color: var(--bone);
    transform: translateY(-1px);
  }


  /* ══════════════════════════════════════════════════
     02. HERO CARD — UPCOMING EXPEDITION
     ══════════════════════════════════════════════════ */

  .pts-hero__card {
    width: 360px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    background: rgba(247,242,232,0.12);
    backdrop-filter: blur(28px) saturate(1.6);
    -webkit-backdrop-filter: blur(28px) saturate(1.6);
    border: 1px solid rgba(247,242,232,0.25);
    border-radius: 20px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.4), inset 0 1px 0 rgba(247,242,232,0.15);
    overflow: hidden;
  }

  .pts-hero__card-photo {
    position: relative;
    height: 240px;
    width: 100%;
    flex-shrink: 0;
    overflow: hidden;
  }

  .pts-hero__card-photo img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    border-radius: 20px 20px 0 0;
  }

  .pts-hero__card-photo-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(6,10,18,0.95) 0%, rgba(6,10,18,0.2) 50%, transparent 100%);
  }

  .pts-hero__card-badge {
    position: absolute;
    bottom: 12px;
    left: 16px;
    display: flex;
    align-items: center;
    gap: var(--s-3);
    background: rgba(6,10,18,0.75);
    border: 1px solid rgba(196,168,98,0.3);
    border-radius: 99px;
    padding: 5px 12px;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: #C4A862;
  }

  .pts-hero__card-badge-dot { font-size: 6px; color: var(--gold); }

  .pts-hero__card-body {
    padding: 20px 22px 22px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .pts-hero__card-terrain {
    font-family: var(--mark);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(247,242,232,0.55);
    display: block;
  }

  .pts-hero__card-title {
    font-family: var(--display);
    font-size: 42px;
    font-weight: 200;
    line-height: 1;
    color: var(--bone);
    margin: 4px 0;
    font-optical-sizing: auto;
  }

  .pts-hero__card-tagline {
    font-family: var(--serif);
    font-style: italic;
    font-size: 14px;
    color: rgba(196,168,98,0.85);
    margin: 0;
    font-optical-sizing: auto;
  }

  .pts-hero__card-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px var(--s-3);
    font-family: var(--sans);
    font-size: 12px;
    color: rgba(247,242,232,0.45);
    margin-top: 4px;
  }

  .pts-hero__card-dot { opacity: 0.28; }

  .pts-hero__card-divider {
    border-top: 1px solid rgba(247,242,232,0.12);
    margin: 14px 0 16px;
  }

  .pts-hero__card-actions {
    display: flex;
    flex-direction: row;
    gap: 10px;
  }

  .pts-hero__card-actions .pts-btn {
    flex: 1;
    text-align: center;
    justify-content: center;
    font-size: 11px;
    padding: 12px 16px;
  }


  /* ══════════════════════════════════════════════════
     03. DIVIDER PHRASE
     ══════════════════════════════════════════════════ */

  .pts-divider-phrase {
    padding-block: clamp(48px, 7svh, 80px);
    background: var(--deep);
    border-top: 1px solid rgba(200,220,240,0.05);
  }

  .pts-divider-phrase__text {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(18px, 2vw, 28px);
    line-height: 1.55;
    color: rgb(var(--sky-rgb) / 0.45);
    max-width: 60ch;
    margin: 0;
    font-optical-sizing: auto;
  }


  /* ══════════════════════════════════════════════════
     04. SCHEDULE
     ══════════════════════════════════════════════════ */

  .pts-schedule { background: var(--navy); }

  .pts-section-title {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(36px, 5vw, 72px);
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--bone);
    margin: 0 0 clamp(48px, 7vw, 88px);
    font-optical-sizing: auto;
    text-wrap: balance;
  }

  .pts-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(12px, 2vw, 20px);
  }

  .pts-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--r-3);
    overflow: hidden;
    background: var(--mid);
    border: 1px solid rgba(200,220,240,0.06);
