---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const upcoming = [
  {
    slug: 'kailash-2026',
    name: 'Kailash',
    terrain: 'Tibet',
    date: 'September 20',
    duration: '10 Days',
    status: 'open',
    bg: 'linear-gradient(160deg, #A8C0D8 0%, #4A6888 45%, #1A2C40 100%)',
  },
  {
    slug: 'arunachala-2026',
    name: 'Arunachala',
    terrain: 'India',
    date: 'November',
    duration: '7 Days',
    status: 'open',
    bg: 'linear-gradient(160deg, #D4A87A 0%, #8C5A3A 50%, #3A1E12 100%)',
  },
  {
    slug: null,
    name: 'Annapurna',
    terrain: 'Nepal',
    date: 'May 2027',
    duration: 'TBA',
    status: 'soon',
    bg: 'linear-gradient(160deg, #B8C8D0 0%, #6080A0 45%, #1E3048 100%)',
  },
  {
    slug: null,
    name: 'Coming Soon',
    terrain: null,
    date: null,
    duration: null,
    status: 'future',
    bg: 'linear-gradient(160deg, #1A2030 0%, #0E1420 100%)',
  },
];

const past = [
  {
    name: 'Mardi Himal',
    terrain: 'Nepal',
    year: '2025',
    participants: '12 participants',
    bg: 'linear-gradient(160deg, #7898B8 0%, #3A5878 50%, #18283A 100%)',
  },
  {
    name: 'Himalayas',
    terrain: 'India',
    year: '2024',
    participants: null,
    bg: 'linear-gradient(160deg, #A0B4C8 0%, #506880 50%, #1E2C3A 100%)',
  },
  {
    name: 'Georgian Highlands',
    terrain: 'Georgia',
    year: '2024',
    participants: '8 participants',
    bg: 'linear-gradient(160deg, #C8D0C8 0%, #8A9688 50%, #3A4035 100%)',
  },
];

const testimonials = [
  {
    quote: 'I returned quieter. More certain of what matters. The mountain doesn\'t explain itself — and neither does the change.',
    name: 'Elena K.',
    location: 'Moscow',
    journey: 'Mardi Himal 2025',
  },
  {
    quote: 'Yakov holds the space without filling it. That quality is rare. The mountains do the work — he ensures you can receive it.',
    name: 'David M.',
    location: 'Berlin',
    journey: 'Georgian Highlands 2024',
  },
  {
    quote: 'Not transformed in any dramatic way — clarified. Like something blurry for years finally came into focus.',
    name: 'Maria T.',
    location: 'Tbilisi',
    journey: 'Pontic Alps 2024',
  },
];
---

<Base
  title="Path of the Spirit — The Open Sky"
  description="Sacred journeys to places of power. Pilgrimages to Kailash, Arunachala, Annapurna and beyond. Led by Yakov Rajuna."
>
  <Nav />
  <main class="pts">

    <!-- ══════════════════════════════════════════
         1. HERO
         ══════════════════════════════════════════ -->

    <section class="pts-hero" aria-label="Path of the Spirit">
      <div class="pts-hero__bg" aria-hidden="true"></div>
      <div class="pts-hero__overlay" aria-hidden="true"></div>

      <div class="pts-hero__inner frame">
        <h1 class="pts-hero__title reveal d1">Path of the Spirit</h1>
        <p class="pts-hero__sub reveal d2">
          Journeys to sacred mountains,<br />
          places of power and inner transformation.
        </p>
        <a href="#upcoming" class="pts-hero__btn reveal d3">Explore Journeys</a>
      </div>

      <div class="pts-hero__scroll" aria-hidden="true">
        <span class="pts-hero__scroll-line"></span>
        <span class="pts-hero__scroll-text">scroll</span>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         2. KAILASH — UPCOMING JOURNEY
         ══════════════════════════════════════════ -->

    <section class="pts-feat" id="upcoming" aria-label="Upcoming journey — Kailash">
      <div class="frame">

        <p class="pts-feat__label reveal">Upcoming Journey</p>

        <div class="pts-feat__body">

          <div class="pts-feat__photo reveal d1">
            <div class="pts-feat__photo-img" style="background: linear-gradient(160deg, #A8C0D8 0%, #4A6888 45%, #1A2C40 100%);" role="img" aria-label="Mount Kailash, Tibet"></div>
            <div class="pts-feat__photo-badge">
              <span class="pts-feat__badge-dot">●</span>
              <span>4 places remaining</span>
            </div>
          </div>

          <div class="pts-feat__content">
            <span class="pts-feat__terrain reveal">Tibet · 6,638m · 10 Days</span>
            <h2 class="pts-feat__title reveal d1">Kailash</h2>
            <p class="pts-feat__tagline reveal d2">The Abode of Shiva</p>

            <div class="pts-feat__meta reveal d2">
              <span>September 20–30, 2026</span>
              <span class="pts-feat__dot">·</span>
              <span>Tibet</span>
              <span class="pts-feat__dot">·</span>
              <span>Max 6 people</span>
            </div>

            <p class="pts-feat__copy reveal d3">
              Mount Kailash has been one of the most revered pilgrimage destinations
              on Earth for thousands of years. This journey is not tourism.
              It is an encounter with a place that has transformed seekers,
              yogis and pilgrims for centuries.
            </p>

            <div class="pts-feat__actions reveal d4">
              <a href="/mountains/kailash-2026" class="pts-btn pts-btn--gold">View Full Journey</a>
              <a href="#register" class="pts-btn pts-btn--ghost">Apply Now</a>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         3. UPCOMING SCHEDULE
         ══════════════════════════════════════════ -->

    <section class="pts-schedule section" aria-label="Upcoming expeditions">
      <div class="frame">

        <h2 class="pts-section-title reveal">Where we go next.</h2>

        <div class="pts-cards">
          {upcoming.map((j, i) => (
            <div class={`pts-card reveal d${(i % 4) + 1} ${j.status === 'future' ? 'pts-card--future' : ''}`}>
              <div class="pts-card__img" style={`background: ${j.bg};`} role="img" aria-label={j.name}>
                <span class="pts-card__img-label">{j.status === 'future' ? 'More to come' : j.name}</span>
                {j.status === 'soon' && <span class="pts-card__badge">Coming Soon</span>}
              </div>
              <div class="pts-card__info">
                {j.terrain && <span class="pts-card__region">{j.terrain}</span>}
                <h3 class="pts-card__name">{j.name}</h3>
                {j.date && (
                  <p class="pts-card__meta">
                    {j.date}{j.duration ? ` · ${j.duration}` : ''}
                  </p>
                )}
                {j.slug && (
                  <a href={`/mountains/${j.slug}`} class="pts-card__link">
                    Learn More
                    <span class="pts-card__link-line" aria-hidden="true"></span>
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>


    <!-- ══════════════════════════════════════════
         4. PAST EXPEDITIONS
         ══════════════════════════════════════════ -->

    <section class="pts-past section" aria-label="Past expeditions">
      <div class="frame">

        <div class="pts-past__header reveal">
          <h2 class="pts-past__title">Past Expeditions</h2>
        </div>

        <div class="pts-past-cards">
          {past.map((p, i) => (
            <div class={`pts-past-card reveal d${i + 1}`}>
              <div class="pts-past-card__img" style={`background: ${p.bg};`} role="img" aria-label={p.name}></div>
              <div class="pts-past-card__info">
                <span class="pts-past-card__region">{p.terrain}</span>
                <h3 class="pts-past-card__name">{p.name}</h3>
                <p class="pts-past-card__meta">
                  {p.year}{p.participants ? ` · ${p.participants}` : ''}
                </p>
                <a href="/connect" class="pts-card__link">
                  Photos & Stories
                  <span class="pts-card__link-line" aria-hidden="true"></span>
                </a>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>


    <!-- ══════════════════════════════════════════
         5. TESTIMONIALS
         ══════════════════════════════════════════ -->

    <section class="pts-tst section" aria-label="Participant voices">
      <div class="frame">

        <p class="pts-tst__label reveal">Participant voices</p>

        <div class="pts-tst__grid">
          {testimonials.map((t, i) => (
            <figure class={`pts-tst__card reveal d${i + 1}`}>
              <span class="pts-tst__mark" aria-hidden="true">"</span>
              <blockquote class="pts-tst__quote">{t.quote}</blockquote>
              <figcaption class="pts-tst__attr">
                <span class="pts-tst__name">{t.name}</span>
                <span class="pts-tst__journey">{t.location} · {t.journey}</span>
              </figcaption>
            </figure>
          ))}
        </div>

      </div>
    </section>


    <!-- ══════════════════════════════════════════
         6. ABOUT THE GUIDE
         ══════════════════════════════════════════ -->

    <section class="pts-guide section" aria-label="About the guide">
      <div class="frame">
        <div class="pts-guide__body">

          <div class="pts-guide__photo reveal">
            <div class="pts-guide__photo-img" role="img" aria-label="Yakov Rajuna"></div>
          </div>

          <div class="pts-guide__content">
            <span class="pts-guide__label reveal">Your guide</span>
            <h2 class="pts-guide__name reveal d1">Yakov Rajuna</h2>

            <div class="pts-guide__stats reveal d2">
              <div class="pts-guide__stat">
                <span class="pts-guide__stat-n">20+</span>
                <span class="pts-guide__stat-l">Years of practice</span>
              </div>
              <div class="pts-guide__stat">
                <span class="pts-guide__stat-n">350+</span>
                <span class="pts-guide__stat-l">Ceremonies</span>
              </div>
              <div class="pts-guide__stat">
                <span class="pts-guide__stat-n">3 500+</span>
                <span class="pts-guide__stat-l">Participants</span>
              </div>
            </div>

            <p class="pts-guide__roles reveal d2">
              Guide · Healer · Teacher · Musician · Expedition leader
            </p>

            <p class="pts-guide__bio reveal d3">
              Yakov has led groups into sacred terrain across Asia, the Caucasus and
              Eastern Europe for two decades. Initiations in Peru and Brazil.
              Each expedition is small, intentional, and led personally.
            </p>

            <a href="/about" class="pts-btn pts-btn--ghost-sm reveal d4">Learn More</a>
          </div>

        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         7. REGISTRATION
         ══════════════════════════════════════════ -->

    <section class="pts-reg section" id="register" aria-label="Apply for a journey">
      <div class="frame frame--sm">

        <h2 class="pts-reg__title reveal">Apply for a Journey</h2>
        <p class="pts-reg__sub reveal d1">Applications are reviewed personally. Places are limited.</p>

        <form class="pts-reg__form reveal d2" action="/connect" method="GET">

          <div class="pts-reg__row">
            <div class="pts-reg__field">
              <label class="pts-reg__label" for="reg-name">Name</label>
              <input class="pts-reg__input" id="reg-name" name="name" type="text" autocomplete="name" placeholder="Your name" required />
            </div>
            <div class="pts-reg__field">
              <label class="pts-reg__label" for="reg-tg">Telegram / WhatsApp</label>
              <input class="pts-reg__input" id="reg-tg" name="telegram" type="text" autocomplete="tel" placeholder="@username or +1 234 567" />
            </div>
          </div>

          <div class="pts-reg__field">
            <label class="pts-reg__label" for="reg-email">Email</label>
            <input class="pts-reg__input" id="reg-email" name="email" type="email" autocomplete="email" placeholder="your@email.com" required />
          </div>

          <div class="pts-reg__field">
            <label class="pts-reg__label" for="reg-msg">Message</label>
            <textarea class="pts-reg__input pts-reg__textarea" id="reg-msg" name="message" placeholder="Which journey interests you?" rows="4"></textarea>
          </div>

          <button class="pts-btn pts-btn--gold pts-reg__submit" type="submit">Apply for Journey</button>

        </form>

      </div>
    </section>

  </main>
  <Footer />
</Base>

<style>

  /* ─── PALETTE ─────────────────────────────────────── */

  .pts {
    --deep:       #080E18;
    --navy:       #0D1929;
    --mid:        #14243A;
    --silver:     #6A8099;
    --sky:        #C8DCF0;
    --sky-rgb:    200 220 240;
    --gold:       #C4A862;
    --gold-hover: #B8983A;
    --bone:       #F0EBE0;
  }

  /* ─── SHARED BUTTONS ──────────────────────────────── */

  .pts-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    padding: 16px 32px;
    border-radius: var(--r-pill);
    border: 1px solid transparent;
    transition: background-color 350ms var(--ease), border-color 350ms var(--ease), color 350ms var(--ease), transform 350ms var(--ease);
    white-space: nowrap;
    cursor: pointer;
  }

  .pts-btn--gold {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--deep);
  }
  .pts-btn--gold:hover {
    background: var(--gold-hover);
    border-color: var(--gold-hover);
    transform: translateY(-1px);
  }

  .pts-btn--ghost {
    background: transparent;
    border-color: rgba(200,220,240,0.28);
    color: rgba(200,220,240,0.80);
  }
  .pts-btn--ghost:hover {
    border-color: rgba(200,220,240,0.55);
    color: var(--bone);
    transform: translateY(-1px);
  }

  .pts-btn--ghost-sm {
    background: transparent;
    border-color: rgba(200,220,240,0.25);
    color: rgba(200,220,240,0.65);
    padding: 13px 26px;
    font-size: 10px;
    font-family: var(--mark);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border-radius: var(--r-pill);
    display: inline-flex;
    transition: all 350ms var(--ease);
  }
  .pts-btn--ghost-sm:hover {
    border-color: rgba(200,220,240,0.50);
    color: var(--bone);
    transform: translateY(-1px);
  }

  /* ─── 1. HERO ─────────────────────────────────────── */

  .pts-hero {
    position: relative;
    height: 100svh;
    min-height: 640px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .pts-hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 55% 30%, rgba(40,80,140,0.55) 0%, transparent 65%),
      radial-gradient(ellipse 50% 80% at 20% 60%, rgba(15,30,60,0.60) 0%, transparent 60%),
      linear-gradient(165deg, #0D1E38 0%, #060E1C 60%, #030810 100%);
  }

  .pts-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(6,10,18,0.80) 0%, transparent 60%);
  }

  .pts-hero__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: var(--s-6);
    max-width: 780px;
  }

  .pts-hero__label {
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(200,220,240,0.40);
    margin: 0;
  }

  .pts-hero__title {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(52px, 8.5vw, 120px);
    line-height: 0.93;
    letter-spacing: -0.02em;
    color: var(--bone);
    margin: 0;
    font-optical-sizing: auto;
    text-wrap: balance;
  }

  .pts-hero__sub {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(17px, 1.7vw, 24px);
    line-height: 1.55;
    color: rgb(var(--sky-rgb) / 0.68);
    margin: 0;
    font-optical-sizing: auto;
  }

  .pts-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    padding: 18px clamp(32px, 8vw, 80px);
    border-radius: var(--r-pill);
    border: 1px solid rgba(200,220,240,0.22);
    color: rgba(200,220,240,0.80);
    background: transparent;
    transition: all 350ms var(--ease);
    margin-top: var(--s-4);
  }
  .pts-hero__btn:hover {
    border-color: rgba(200,220,240,0.55);
    color: var(--bone);
    transform: translateY(-1px);
  }

  .pts-hero__scroll {
    position: absolute;
    right: var(--frame-x);
    bottom: 40px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-3);
  }

  .pts-hero__scroll-line {
    display: block;
    width: 1px;
    height: 52px;
    background: linear-gradient(to bottom, rgba(200,220,240,0.50), rgba(200,220,240,0.05));
  }

  .pts-hero__scroll-text {
    font-family: var(--mark);
    font-size: 9px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(200,220,240,0.28);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  /* ─── 2. KAILASH FEATURED ─────────────────────────── */

  .pts-feat {
    background: var(--deep);
    padding-block: clamp(80px, 14svh, 160px);
    border-top: 1px solid rgba(200,220,240,0.05);
  }

  .pts-feat__label {
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(196,168,98,0.70);
    margin: 0 0 clamp(40px, 6vw, 80px);
    display: block;
  }

  .pts-feat__body {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: clamp(40px, 6vw, 100px);
    align-items: center;
  }

  .pts-feat__photo {
    position: relative;
  }

  .pts-feat__photo-img {
    border-radius: var(--r-3);
    aspect-ratio: 3/4;
    overflow: hidden;
  }

  .pts-feat__photo-badge {
    position: absolute;
    bottom: 18px;
    left: 18px;
    display: flex;
    align-items: center;
    gap: var(--s-3);
    background: rgba(6,10,18,0.80);
    backdrop-filter: blur(10px);
    padding: 9px 15px;
    border-radius: var(--r-pill);
    border: 1px solid rgba(196,168,98,0.22);
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .pts-feat__badge-dot {
    font-size: 7px;
    color: var(--gold);
  }

  .pts-feat__content {
    display: flex;
    flex-direction: column;
    gap: var(--s-6);
  }

  .pts-feat__terrain {
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(200,220,240,0.35);
    display: block;
  }

  .pts-feat__title {
    font-family: var(--display);
    font-weight: 200;
    font-size: clamp(64px, 10vw, 140px);
    line-height: 0.88;
    letter-spacing: -0.03em;
    color: var(--bone);
    margin: 0;
    font-optical-sizing: auto;
  }

  .pts-feat__tagline {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(18px, 1.8vw, 26px);
    color: rgba(196,168,98,0.75);
    margin: 0;
    line-height: 1.4;
    font-optical-sizing: auto;
  }

  .pts-feat__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px var(--s-4);
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 300;
    color: rgba(200,220,240,0.38);
    padding-top: var(--s-4);
    border-top: 1px solid rgba(200,220,240,0.07);
  }

  .pts-feat__dot { opacity: 0.28; }

  .pts-feat__copy {
    font-family: var(--sans);
    font-weight: 300;
    font-size: clamp(15px, 1.4vw, 17px);
    line-height: 1.85;
    color: rgb(var(--sky-rgb) / 0.70);
    margin: 0;
    max-width: 48ch;
  }

  .pts-feat__actions {
    display: flex;
    align-items: center;
    gap: var(--s-4);
    flex-wrap: wrap;
    margin-top: var(--s-2);
  }

  /* ─── 3. UPCOMING SCHEDULE ────────────────────────── */

  .pts-schedule {
    background: var(--navy);
  }

  .pts-section-title {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(36px, 5vw, 72px);
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--bone);
    margin: 0 0 clamp(48px, 7vw, 88px);
    font-optical-sizing: auto;
    text-wrap: balance;
  }

  .pts-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(12px, 2vw, 20px);
  }

  .pts-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--r-3);
    overflow: hidden;
    background: var(--mid);
    border: 1px solid rgba(200,220,240,0.06);
    transition: transform 400ms var(--ease), box-shadow 400ms var(--ease);
  }
  .pts-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.35);
  }

  .pts-card--future { opacity: 0.35; }
  .pts-card--future:hover { transform: none; box-shadow: none; }

  .pts-card__img {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .pts-card__img-label {
    position: absolute;
    bottom: 14px;
    left: 16px;
    font-family: var(--mark);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: rgba(240,236,228,0.50);
  }

  .pts-card__badge {
    position: absolute;
    top: 14px;
    right: 14px;
    font-family: var(--mark);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
