---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getJourney } from '../../data/mountains';
import '../../styles/global.css';

const journey = getJourney('kailash-2026')!;
---

<Base
  title="Kailash 2026 — Sacred Expedition — The Open Sky"
  description="Ten days around Mount Kailash, Tibet. The kora at altitude through one of the most remote and revered landscapes on earth. Led by Yakov Rajuna."
>
  <Nav />
  <main class="kl">

    <!-- ══════════════════════════════════════════
         1. HERO
         ══════════════════════════════════════════ -->

    <section class="kl-hero" aria-label="Kailash 2026 expedition">
      <img
        class="kl-hero__img"
        src="/images/mountains/kailash-hero.jpg"
        alt="Mount Kailash, Tibet"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div class="kl-hero__overlay" aria-hidden="true"></div>

      <div class="kl-hero__inner frame">
        <h1 class="kl-hero__title reveal d1">Kailash</h1>
        <p class="kl-hero__date reveal d2">Tibet · September 2026</p>
        <a href="#apply" class="kl-hero__cta reveal d3">Apply for this expedition</a>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         2. A WORD FROM YAKOV
         ══════════════════════════════════════════ -->

    <section class="kl-letter" aria-label="A word from Yakov">
      <div class="frame kl-letter__inner">
        <p class="kl-letter__label">A word from Yakov</p>
        <div class="kl-letter__text">
          <p>
            I first went to Kailash in 2017. I had led groups for twelve years before that —
            the Caucasus, the Himalayas, the Amazon. I thought I understood what mountains do to people.
          </p>
          <p>
            On the second day of the kora, at around 5,200 metres, one of the participants — a doctor from Berlin,
            not a spiritual person by her own description — stopped walking and sat down in the middle of the path.
            She didn't speak for forty minutes. When she got up, she said: "Something just fell away.
            I don't know what it was, but it had been there my whole life."
          </p>
          <p>
            I have seen some version of this on every Kailash expedition since.
            Not always that dramatic. Sometimes quieter. But always real.
          </p>
          <p>
            The mountain does something that is difficult to explain without sounding like a brochure.
            So I won't try. I'll just say: come and see.
          </p>
        </div>
        <p class="kl-letter__sig">— Yakov Rajuna</p>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         3. WHY KAILASH
         ══════════════════════════════════════════ -->

    <section class="kl-why2" aria-label="Why Kailash">
      <div class="frame">
        <h2 class="kl-why2__heading reveal">Why Kailash</h2>

        <div class="kl-why2__rows">
          {([
            {
              title: 'It has never been climbed',
              body: 'No permit exists. No ascent has ever been authorised. The kora — three days circumambulating the mountain at 4,800–5,630m — is the only way in. You come not to conquer, but to be in its presence.',
            },
            {
              title: 'Four traditions meet here',
              body: 'Hindu, Buddhist, Jain, Bonpo — each tradition considers Kailash the axis of the world. No single religion owns it. The convergence creates a charge in the landscape that is difficult to account for by geology alone.',
            },
            {
              title: 'The terrain is singular',
              body: 'The Barkha Plateau. Lake Manasarovar. The red and black valleys of the north face. Drolma Pass at 5,630m. Photographers come and say the images don\'t capture it. They\'re right. You have to be there.',
            },
          ] as const).map((item, i) => (
            <div class={`kl-why2__row reveal d${i + 1}`}>
              <h3 class="kl-why2__row-title">{item.title}</h3>
              <p class="kl-why2__row-body">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         4. WHAT THIS JOURNEY GIVES
         ══════════════════════════════════════════ -->

    <section class="kl-give" aria-label="What this journey gives you">
      <div class="frame">
        <h2 class="kl-give__heading reveal">What this journey<br/>may give you</h2>

        <div class="kl-give__grid">
          {([
            {
              title: 'Clarity',
              body: 'Altitude and silence together dissolve the noise that is usually constant. What remains tends to be the things that actually matter.',
            },
            {
              title: 'Different scale',
              body: 'Standing below 6,638 metres of unmoved mountain changes what feels large about ordinary life. Permanently.',
            },
            {
              title: 'Physical achievement',
              body: 'The kora is 52km on foot at altitude. Your body will remember this for a long time after your mind has moved on.',
            },
            {
              title: 'Ceremony',
              body: 'Integrated ritual at high passes and sacred sites — not performance, not tourism. Participation. In something older than any of us.',
            },
            {
              title: 'Real company',
              body: 'Six people, three days on foot at extreme altitude. You will know these people. Not as acquaintances — as witnesses.',
            },
            {
              title: 'Integration',
              body: 'A closing circle before return. Space to begin making sense of what happened before re-entering ordinary life.',
            },
          ] as const).map((item, i) => (
            <div class={`kl-give__card reveal d${(i % 3) + 1}`}>
              <h3 class="kl-give__card-title">{item.title}</h3>
              <p class="kl-give__card-body">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         5. EXPEDITION ROUTE
         ══════════════════════════════════════════ -->

    <section class="kl-route" aria-label="Expedition route">
      <div class="frame">
        <h2 class="kl-route__heading reveal">Expedition route</h2>

        <div class="kl-route__phases">
          {(journey.structure ?? []).map((phase, i) => (
            <div class={`kl-route__phase reveal d${(i % 3) + 1}`}>
              <span class="kl-route__phase-label">{phase.phase}</span>
              <p class="kl-route__phase-text">{phase.description}</p>
            </div>
          ))}
        </div>

        <div class="kl-route__meta reveal d2">
          {([
            { label: 'Dates',      value: journey.date },
            { label: 'Duration',   value: journey.duration },
            { label: 'Location',   value: journey.location },
            { label: 'Altitude',   value: journey.altitude ?? '—' },
            { label: 'Group size', value: journey.groupSize ?? '—' },
            { label: 'Difficulty', value: journey.difficulty ?? '—' },
          ] as const).map(row => (
            <div class="kl-route__meta-row">
              <span class="kl-route__meta-label">{row.label}</span>
              <span class="kl-route__meta-val">{row.value}</span>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         6. INCLUDED / NOT INCLUDED
         ══════════════════════════════════════════ -->

    <section class="kl-incl" aria-label="What's included">
      <div class="frame">
        <h2 class="kl-incl__heading reveal">Included</h2>
        <div class="kl-incl__cols">

          <div class="kl-incl__col">
            <p class="kl-incl__col-label reveal">In the expedition</p>
            <ul class="kl-incl__list" role="list">
              {(journey.included ?? []).map((item, i) => (
                <li class={`kl-incl__item reveal d${(i % 2) + 1}`}>{item}</li>
              ))}
            </ul>
          </div>

          <div class="kl-incl__col">
            <p class="kl-incl__col-label reveal">Arranged separately</p>
            <ul class="kl-incl__list kl-incl__list--dim" role="list">
              {(['International flights', 'Travel insurance (mandatory)', 'Personal trekking equipment', 'Chinese visa (we provide support)'] as const).map((item, i) => (
                <li class={`kl-incl__item reveal d${(i % 2) + 1}`}>{item}</li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         7. WHY TRAVEL WITH YAKOV
         ══════════════════════════════════════════ -->

    <section class="kl-guide" aria-label="Why travel with Yakov">
      <div class="frame">
        <div class="kl-guide__body">

          <div class="kl-guide__photo reveal">
            <div class="kl-guide__photo-img" role="img" aria-label="Yakov Rajuna"></div>
          </div>

          <div class="kl-guide__content">
            <p class="kl-guide__kicker">Your guide</p>
            <h2 class="kl-guide__name reveal d1">Yakov Rajuna</h2>

            <p class="kl-guide__bio reveal d2">
              Twenty years leading groups into sacred terrain across Asia, the Caucasus,
              and Eastern Europe. Every expedition small, personal, led entirely by him —
              not coordinated remotely, not delegated to a local agency.
            </p>

            <div class="kl-guide__stats reveal d3">
              {([
                { n: '20+', label: 'Years' },
                { n: '350+', label: 'Ceremonies' },
                { n: '3,500+', label: 'Participants' },
              ] as const).map(s => (
                <div class="kl-guide__stat">
                  <span class="kl-guide__stat-n">{s.n}</span>
                  <span class="kl-guide__stat-l">{s.label}</span>
                </div>
              ))}
            </div>

            <a href="/about" class="kl-guide__link reveal d4">About Yakov →</a>
          </div>

        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         8. TESTIMONIALS — always last before FAQ
         ══════════════════════════════════════════ -->

    <section class="kl-tst" aria-label="Participant voices">
      <div class="frame">
        <h2 class="kl-tst__heading reveal">From participants</h2>

        <div class="kl-tst__grid">
          {([
            {
              quote: 'I returned quieter. More certain of what matters. The mountain does not explain itself, and neither does the change.',
              name: 'Elena K.',
              detail: 'Moscow · Mardi Himal 2025',
            },
            {
              quote: 'Yakov holds the space without filling it. That quality is rare. The mountains do the work. He ensures you can receive it.',
              name: 'David M.',
              detail: 'Berlin · Georgian Highlands 2024',
            },
            {
              quote: 'Not transformed in any dramatic way. Clarified. Like something blurry for years finally came into focus.',
              name: 'Maria T.',
              detail: 'Tbilisi · Pontic Alps 2024',
            },
          ] as const).map((t, i) => (
            <figure class={`kl-tst__card reveal d${i + 1}`}>
              <span class="kl-tst__glyph" aria-hidden="true">"</span>
              <blockquote class="kl-tst__quote">{t.quote}</blockquote>
              <figcaption class="kl-tst__attr">
                <span class="kl-tst__name">{t.name}</span>
                <span class="kl-tst__detail">{t.detail}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         9. FAQ
         ══════════════════════════════════════════ -->

    <section class="kl-faq" aria-label="Questions">
      <div class="frame">
        <h2 class="kl-faq__heading reveal">Questions</h2>

        <div class="kl-faq__list">
          {([
            {
              q: 'What physical preparation is needed?',
              a: 'You should be able to walk 6–8 hours daily at altitudes between 4,800–5,600 metres, carrying a light day pack. The kora covers approximately 52km over three days. No technical climbing is involved. Cardiovascular fitness matters more than mountain experience.',
            },
            {
              q: 'When should I confirm my place?',
              a: 'Places for September 2026 are limited to six. The first step is a short conversation with Yakov. Write through the form below or via Telegram — he responds personally to each message.',
            },
            {
              q: 'Is this a religious event?',
              a: 'No particular religion or practice is required or assumed. The expedition respects all traditions present at Kailash and is grounded in personal, direct experience rather than doctrine. People of any background join these journeys.',
            },
            {
              q: 'What happens at altitude?',
              a: 'Two acclimatisation days are built into the programme. Emergency oxygen is carried throughout the kora. We hold safety above all other considerations — we do not continue if a participant cannot safely do so.',
            },
            {
              q: 'Can I join as a solo traveller?',
              a: 'Most participants arrive alone and meet the group for the first time in Lhasa or Kathmandu. Shared experience in a small group at altitude creates its own form of connection.',
            },
            {
              q: 'What is the cost of the expedition?',
              a: 'Investment details are shared during the initial conversation. The price reflects the complexity of Tibet permits, emergency logistics, small group format, and the fully personal accompaniment throughout.',
            },
          ] as const).map((item, i) => (
            <details class={`kl-faq__item reveal d${(i % 3) + 1}`}>
              <summary class="kl-faq__q">{item.q}</summary>
              <p class="kl-faq__a">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         10. FINAL APPLY
         ══════════════════════════════════════════ -->

    <section class="kl-apply" id="apply" aria-label="Apply">
      <div class="frame">
        <div class="kl-apply__inner">
          <h2 class="kl-apply__title reveal d1">Kailash.</h2>
          <p class="kl-apply__body reveal d2">
            Write a short message. Tell Yakov where you are and what you are looking for.
            He responds personally. Places for September 2026 are limited to six.
          </p>
          <div class="kl-apply__actions reveal d3">
            <a href="/connect" class="kl-apply__btn kl-apply__btn--gold">Express Interest</a>
            <a
              href="https://t.me/yakovrajuna"
              class="kl-apply__btn kl-apply__btn--ghost"
              rel="noopener noreferrer"
              target="_blank"
            >Telegram</a>
          </div>
          <p class="kl-apply__meta reveal d4">6 places · September 20, 2026 · Investment on enquiry</p>
          <a href="/mountains" class="kl-apply__back reveal d5">← All mountain expeditions</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Base>

<style>

  /* ─── PALETTE ─────────────────────────────────── */

  .kl {
    --deep:   #080E18;
    --navy:   #0D1929;
    --mid:    #14243A;
    --silver: #6A8099;
    --sky:    #C8DCF0;
    --gold:   #C4A862;
    --bone:   #F0EBE0;
    --ink:    #2C2A26;
  }

  /* ─── NAV OVERRIDE ────────────────────────────── */

  :global(.nav:not(.nav--scrolled) .nav__link) {
    color: rgba(200,220,240,0.65);
  }
  :global(.nav:not(.nav--scrolled) .nav__link--connect) {
    color: rgba(196,168,98,0.80);
  }
  :global(.nav:not(.nav--scrolled) .nav__wordmark) {
    color: rgba(200,220,240,0.18);
    pointer-events: none;
  }
  :global(.nav:not(.nav--scrolled) .nav__social) {
    color: rgba(200,220,240,0.45);
  }


  /* ══════════════════════════════════════════════
     1. HERO
     ══════════════════════════════════════════════ */

  .kl-hero {
    position: relative;
    height: 100svh;
    min-height: 680px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .kl-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
    display: block;
    filter: contrast(1.08) saturate(0.78) brightness(0.90);
    transform-origin: 50% 25%;
    will-change: transform;
    animation: klHeroFloat 22s ease-in-out infinite alternate;
  }

  @keyframes klHeroFloat {
    from { transform: scale(1.00); }
    to   { transform: scale(1.05) translateY(-8px); }
  }

  .kl-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(to bottom,
        rgba(6,10,20,0.32) 0%,
        rgba(6,10,20,0.08) 16%,
        transparent 38%
      ),
      linear-gradient(to top,
        rgba(4,7,14,0.99) 0%,
        rgba(4,7,14,0.82) 16%,
        rgba(4,7,14,0.44) 34%,
        rgba(4,7,14,0.12) 52%,
        transparent 72%
      ),
      linear-gradient(108deg,
        rgba(6,10,20,0.48) 0%,
        rgba(6,10,20,0.18) 28%,
        transparent 52%
      ),
      radial-gradient(ellipse 88% 76% at 50% 28%,
        transparent 48%,
        rgba(4,7,14,0.28) 100%
      );
  }

  .kl-hero__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: var(--s-6);
    /* Higher title — reveal more mountain */
    padding-bottom: clamp(130px, 22svh, 260px);
  }

  .kl-hero__title {
    font-family: var(--display);
    font-weight: 200;
    font-size: clamp(80px, 14vw, 200px);
    line-height: 0.86;
    letter-spacing: -0.04em;
    color: var(--bone);
    margin: 0;
    font-optical-sizing: auto;
    text-shadow: 0 2px 48px rgba(4,7,14,0.55);
  }

  .kl-hero__date {
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(196,168,98,0.62);
    margin: 0;
  }

  .kl-hero__cta {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    padding: 18px 44px;
    border-radius: var(--r-pill);
    background: var(--gold);
    border: 1px solid var(--gold);
    color: var(--deep);
    transition: background-color 350ms var(--ease), border-color 350ms var(--ease), transform 350ms var(--ease);
  }
  .kl-hero__cta:hover {
    background: #B8983A;
    border-color: #B8983A;
    transform: translateY(-2px);
  }


  /* ══════════════════════════════════════════════
     2. LETTER FROM YAKOV
     ══════════════════════════════════════════════ */

  .kl-letter {
    background: var(--deep);
    padding-block: clamp(96px, 16svh, 180px);
  }

  .kl-letter__inner {
    max-width: 680px;
  }

  .kl-letter__label {
    font-family: var(--mark);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(196,168,98,0.52);
    margin: 0 0 clamp(36px, 5vw, 56px);
  }

  .kl-letter__text {
    display: flex;
    flex-direction: column;
    gap: clamp(18px, 2.5vw, 26px);
  }

  .kl-letter__text p {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(17px, 1.7vw, 22px);
    line-height: 1.82;
    color: rgba(200,220,240,0.68);
    margin: 0;
    font-optical-sizing: auto;
    text-wrap: pretty;
  }

  .kl-letter__sig {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(15px, 1.4vw, 18px);
    color: rgba(196,168,98,0.50);
    margin: clamp(40px, 6vw, 64px) 0 0;
  }


  /* ══════════════════════════════════════════════
     3. WHY KAILASH
     ══════════════════════════════════════════════ */

  .kl-why2 {
    background: var(--navy);
    padding-block: clamp(96px, 16svh, 180px);
  }

  .kl-why2__heading {
    font-family: var(--display);
    font-weight: 200;
    font-size: clamp(44px, 7vw, 110px);
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--bone);
    margin: 0 0 clamp(64px, 10vw, 100px);
    font-optical-sizing: auto;
    text-wrap: balance;
  }

  .kl-why2__rows {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(200,220,240,0.07);
  }

  .kl-why2__row {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: clamp(32px, 5vw, 80px);
    padding-block: clamp(36px, 5vw, 56px);
    border-bottom: 1px solid rgba(200,220,240,0.06);
    align-items: baseline;
  }

  .kl-why2__row-title {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(16px, 1.5vw, 20px);
    letter-spacing: -0.01em;
    color: rgba(220,235,248,0.85);
    margin: 0;
    font-optical-sizing: auto;
    font-style: italic;
  }

  .kl-why2__row-body {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 15px;
    line-height: 1.85;
    color: rgba(200,220,240,0.55);
    margin: 0;
    max-width: 58ch;
    text-wrap: pretty;
  }


  /* ══════════════════════════════════════════════
     4. WHAT THIS JOURNEY GIVES
     ══════════════════════════════════════════════ */

  .kl-give {
    background: var(--deep);
    padding-block: clamp(96px, 16svh, 180px);
  }

  .kl-give__heading {
    font-family: var(--display);
    font-weight: 200;
    font-size: clamp(44px, 7vw, 100px);
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--bone);
    margin: 0 0 clamp(64px, 10vw, 100px);
    font-optical-sizing: auto;
    text-wrap: balance;
  }

  .kl-give__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(56px, 8vw, 96px) clamp(40px, 6vw, 72px);
  }

  .kl-give__card {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }

  .kl-give__card-title {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(16px, 1.4vw, 19px);
    color: rgba(196,168,98,0.72);
    margin: 0;
    font-optical-sizing: auto;
  }

  .kl-give__card-body {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 14px;
    line-height: 1.85;
    color: rgba(200,220,240,0.52);
    margin: 0;
    text-wrap: pretty;
  }


  /* ══════════════════════════════════════════════
     5. EXPEDITION ROUTE
     ══════════════════════════════════════════════ */

  .kl-route {
    background: var(--navy);
    padding-block: clamp(96px, 16svh, 180px);
  }

  .kl-route__heading {
    font-family: var(--display);
    font-weight: 200;
    font-size: clamp(44px, 7vw, 110px);
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--bone);
    margin: 0 0 clamp(64px, 10vw, 100px);
    font-optical-sizing: auto;
  }

  .kl-route__phases {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(200,220,240,0.07);
    margin-bottom: clamp(56px, 8vw, 96px);
  }

  .kl-route__phase {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: clamp(24px, 4vw, 56px);
    padding-block: clamp(28px, 4vw, 44px);
    border-bottom: 1px solid rgba(200,220,240,0.06);
    align-items: baseline;
  }

  .kl-route__phase-label {
    font-family: var(--mark);
    font-size: 9px;
    font-weight: 600;
