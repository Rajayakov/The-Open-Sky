---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getJourney } from '../../data/mountains';
import '../../styles/global.css';

const journey = getJourney('kailash-2026')!;
---

<Base
  title="Kailash 2026 — Sacred Expedition — The Open Sky"
  description="Ten days around Mount Kailash, Tibet. The kora at altitude through one of the most remote and revered landscapes on earth. Led by Yakov Rajuna."
>
  <Nav />
  <main class="kl">

    <!-- ══════════════════════════════════════════
         1. HERO
         ══════════════════════════════════════════ -->

    <section class="kl-hero" aria-label="Kailash 2026 expedition">
      <img
        class="kl-hero__img"
        src="/images/mountains/kailash-hero.jpg"
        alt="Mount Kailash with prayer flags and stupa, Tibet"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div class="kl-hero__overlay" aria-hidden="true"></div>

      <div class="kl-hero__inner frame">
        <nav class="kl-breadcrumb reveal" aria-label="Breadcrumb">
          <a href="/mountains" class="kl-breadcrumb__link">Mountains</a>
          <span aria-hidden="true" class="kl-breadcrumb__sep">→</span>
          <span class="kl-breadcrumb__current">Kailash</span>
        </nav>

        <div class="kl-hero__tags reveal d1">
          <span class="kl-hero__tag">Tibet</span>
          <span class="kl-hero__tag-dot" aria-hidden="true">·</span>
          <span class="kl-hero__tag">6,638m</span>
          <span class="kl-hero__tag-dot" aria-hidden="true">·</span>
          <span class="kl-hero__tag">10 Days</span>
        </div>

        <h1 class="kl-hero__title reveal d2">Kailash</h1>
        <p class="kl-hero__sub reveal d2">The Abode of Shiva</p>

        <div class="kl-hero__meta reveal d3">
          <span>September 20–30, 2026</span>
          <span class="kl-hero__meta-dot" aria-hidden="true">·</span>
          <span>Max 6 people</span>
        </div>

        <a href="#apply" class="kl-hero__cta reveal d4">Apply for this expedition</a>
      </div>

    </section>


    <!-- ══════════════════════════════════════════
         2. INTRODUCTION
         ══════════════════════════════════════════ -->

    <section class="kl-intro" aria-label="Introduction">
      <div class="frame kl-intro__inner">
        <p class="kl-intro__text reveal">
          Mount Kailash has never been climbed. Not for lack of attempt — but because
          the mountain is considered too sacred to ascend by any tradition that holds
          it holy. You come not to conquer, but to circumambulate. The kora — three days
          of walking around the mountain at altitudes above 5,000 metres — is one of the
          most demanding and most ancient pilgrimage routes on earth.
        </p>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         3. WHY PEOPLE COME
         ══════════════════════════════════════════ -->

    <section class="kl-why section" aria-label="Why people come">
      <div class="frame">
        <h2 class="kl-section-title reveal">Why People Come</h2>

        <div class="kl-why__grid">
          {([
            {
              n: '01',
              title: 'Pilgrimage',
              body: 'To walk around Kailash is to participate in something continuous across more than a thousand years. Hindus, Buddhists, Jains, Bonpo — all traditions converge here. The mountain does not belong to any one of them.',
            },
            {
              n: '02',
              title: 'Inner Work',
              body: 'The kora strips away what is not necessary. Three days on foot at altitude, in silence, in small company — what remains is rarely ordinary. People return changed in ways that take months to understand.',
            },
            {
              n: '03',
              title: 'The Landscape',
              body: 'The terrain surrounding Kailash — the Barkha Plateau, Lake Manasarovar, the red and black valleys — carries a quality that is difficult to translate into language. You have to be there.',
            },
            {
              n: '04',
              title: 'The Encounter',
              body: 'The mountain has never been summited. Not out of inability, but reverence. You do not conquer Kailash. You meet it. That difference in relationship changes something in how you approach the journey.',
            },
          ] as const).map((item, i) => (
            <div class={`kl-why__item reveal d${i + 1}`}>
              <h3 class="kl-why__title">{item.title}</h3>
              <p class="kl-why__body">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         4. THE JOURNEY
         ══════════════════════════════════════════ -->

    <section class="kl-journey section" aria-label="The journey">
      <div class="frame">
        <h2 class="kl-section-title reveal">The Journey</h2>

        <div class="kl-journey__layout">

          <div class="kl-journey__phases">
            {(journey.structure ?? []).map((phase, i) => (
              <div class={`kl-phase reveal d${(i % 3) + 1}`}>
                <span class="kl-phase__label">{phase.phase}</span>
                <p class="kl-phase__text">{phase.description}</p>
              </div>
            ))}
          </div>

          <aside class="kl-journey__panel reveal d2">
            <h3 class="kl-panel__title">Expedition Details</h3>
            <div class="kl-panel__rows">
              {([
                { label: 'Dates',      value: journey.date },
                { label: 'Duration',   value: journey.duration },
                { label: 'Location',   value: journey.location },
                { label: 'Altitude',   value: journey.altitude ?? '—' },
                { label: 'Group',      value: journey.groupSize ?? '—' },
                { label: 'Difficulty', value: journey.difficulty ?? '—' },
              ] as const).map(row => (
                <div class="kl-panel__row">
                  <span class="kl-panel__row-label">{row.label}</span>
                  <span class="kl-panel__row-val">{row.value}</span>
                </div>
              ))}
            </div>
            <a href="#apply" class="kl-panel__cta">Apply for this expedition</a>
          </aside>

        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         5. WHAT THE EXPEDITION OFFERS
         ══════════════════════════════════════════ -->

    <section class="kl-offers section" aria-label="What the expedition offers">
      <div class="frame">
        <h2 class="kl-section-title--light reveal">What the Expedition Offers</h2>

        <div class="kl-offers__list">
          {([
            {
              title: 'Personal Accompaniment',
              body: 'Yakov accompanies the group throughout all ten days — not as a logistics coordinator, but as a guide in the full sense.',
            },
            {
              title: 'Ceremony on the Kora',
              body: 'Ceremonies at high passes and sacred sites during the three-day circumambulation. Integrated into the walk, not added onto it.',
            },
            {
              title: 'Small Group',
              body: 'Six participants maximum. The group size is not a marketing choice — it is a condition of the experience.',
            },
            {
              title: 'Full Logistics',
              body: 'Tibet travel permits, Chinese visas, accommodation, ground transport, and all meals on route fully arranged.',
            },
            {
              title: 'Altitude Support',
              body: 'Emergency oxygen carried throughout. Two acclimatisation days built in. We do not continue if a participant cannot safely do so.',
            },
            {
              title: 'Integration',
              body: 'A closing circle in the final days. Space to begin digesting what happened before returning to ordinary life.',
            },
          ] as const).map((item, i) => (
            <div class={`kl-offer-row reveal d${(i % 2) + 1}`}>
              <h3 class="kl-offer-row__title">{item.title}</h3>
              <p class="kl-offer-row__body">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         6. ABOUT THE GUIDE
         ══════════════════════════════════════════ -->

    <section class="kl-guide section" aria-label="About the guide">
      <div class="frame">
        <div class="kl-guide__body">

          <div class="kl-guide__photo reveal">
            <div class="kl-guide__photo-img" role="img" aria-label="Yakov Rajuna"></div>
          </div>

          <div class="kl-guide__content">
            <h2 class="kl-guide__name reveal d1">Yakov Rajuna</h2>

            <p class="kl-guide__bio reveal d2">
              Two decades leading groups into sacred terrain across Asia, the Caucasus,
              and Eastern Europe. Over 350 ceremonies. 3,500+ participants. Initiations
              in the Amazonian, South Indian, and Himalayan traditions — each expedition
              small, personal, led entirely by him.
            </p>

            <a href="/about" class="kl-guide__link reveal d3">About Yakov →</a>
          </div>

        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         7. QUESTIONS
         ══════════════════════════════════════════ -->

    <section class="kl-faq section" aria-label="Questions">
      <div class="frame">
        <h2 class="kl-section-title reveal">Questions</h2>

        <div class="kl-faq__list">
          {([
            {
              q: 'What physical preparation is needed?',
              a: 'You should be able to walk 6–8 hours daily at altitudes between 4,800–5,600 metres, carrying a light day pack. The kora covers approximately 52km over three days. No technical climbing is involved. Cardiovascular fitness matters more than mountain experience.',
            },
            {
              q: 'When should I confirm my place?',
              a: 'Places for September 2026 are limited to six. The first step is a short conversation with Yakov. Write through the form below or via Telegram — he responds personally to each message.',
            },
            {
              q: 'Is this a religious event?',
              a: 'No particular religion or practice is required or assumed. The expedition respects all traditions present at Kailash and is grounded in personal, direct experience rather than doctrine. People of any background join these journeys.',
            },
            {
              q: 'What happens at altitude?',
              a: 'Two acclimatisation days are built into the programme. Emergency oxygen is carried throughout the kora. We hold safety above all other considerations — we do not continue if a participant cannot safely do so.',
            },
            {
              q: 'Can I join as a solo traveller?',
              a: 'Most participants arrive alone and meet the group for the first time in Lhasa or Kathmandu. Shared experience in a small group at altitude creates its own form of connection.',
            },
            {
              q: 'What is the cost of the expedition?',
              a: 'Investment details are shared during the initial conversation. The price reflects the complexity of Tibet permits, emergency logistics, small group format, and the fully personal accompaniment throughout.',
            },
          ] as const).map((item, i) => (
            <details class={`kl-faq__item reveal d${(i % 3) + 1}`}>
              <summary class="kl-faq__q">{item.q}</summary>
              <p class="kl-faq__a">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         8. FINAL CTA
         ══════════════════════════════════════════ -->

    <section class="kl-apply section" id="apply" aria-label="Apply">
      <div class="frame">
        <div class="kl-apply__inner">
          <h2 class="kl-apply__title reveal d1">Write a short message.</h2>
          <p class="kl-apply__body reveal d2">
            Tell Yakov where you are and what you are looking for. He responds personally
            to each message. Places for September 2026 are limited to six.
          </p>
          <div class="kl-apply__actions reveal d3">
            <a href="/connect" class="kl-apply__btn kl-apply__btn--gold">Express Interest</a>
            <a
              href="https://t.me/yakovrajuna"
              class="kl-apply__btn kl-apply__btn--ghost"
              rel="noopener noreferrer"
              target="_blank"
            >Join Telegram</a>
          </div>
          <a href="/mountains" class="kl-apply__back reveal d4">← All mountain expeditions</a>
        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════
         9. TESTIMONIALS
         ══════════════════════════════════════════ -->

    <section class="kl-tst section" aria-label="Participant voices">
      <div class="frame">
        <h2 class="kl-section-title--light reveal">From Participants</h2>

        <div class="kl-tst__list">
          {([
            {
              quote: 'I returned quieter. More certain of what matters. The mountain doesn\'t explain itself — and neither does the change.',
              name: 'Elena K.',
              detail: 'Moscow · Mardi Himal 2025',
            },
            {
              quote: 'Yakov holds the space without filling it. That quality is rare. The mountains do the work — he ensures you can receive it.',
              name: 'David M.',
              detail: 'Berlin · Georgian Highlands 2024',
            },
            {
              quote: 'Not transformed in any dramatic way — clarified. Like something blurry for years finally came into focus.',
              name: 'Maria T.',
              detail: 'Tbilisi · Pontic Alps 2024',
            },
          ] as const).map((t, i) => (
            <figure class={`kl-tst__row reveal d${(i % 2) + 1}`}>
              <p class="kl-tst__quote">"{t.quote}"</p>
              <figcaption class="kl-tst__attr">
                <span class="kl-tst__name">{t.name}</span>
                <span class="kl-tst__detail">{t.detail}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Base>

<style>

  /* ─── PALETTE ─────────────────────────────────── */

  .kl {
    --deep:   #080E18;
    --navy:   #0D1929;
    --mid:    #14243A;
    --warm:   #E8E4DA;
    --silver: #6A8099;
    --sky:    #C8DCF0;
    --gold:   #C4A862;
    --bone:   #F0EBE0;
    --ink:    #2C2A26;
  }

  /* ─── NAV OVERRIDE ────────────────────────────── */

  :global(.nav:not(.nav--scrolled) .nav__link) {
    color: rgba(200,220,240,0.65);
  }
  :global(.nav:not(.nav--scrolled) .nav__link--connect) {
    color: rgba(196,168,98,0.80);
  }
  :global(.nav:not(.nav--scrolled) .nav__wordmark) {
    color: rgba(200,220,240,0.18);
    pointer-events: none;
  }
  :global(.nav:not(.nav--scrolled) .nav__social) {
    color: rgba(200,220,240,0.45);
  }


  /* ══════════════════════════════════════════════
     1. HERO
     ══════════════════════════════════════════════ */

  .kl-hero {
    position: relative;
    height: 100svh;
    min-height: 680px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .kl-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  .kl-hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top,
        rgba(6,10,18,0.97) 0%,
        rgba(6,10,18,0.76) 32%,
        rgba(6,10,18,0.30) 60%,
        rgba(6,10,18,0.08) 82%,
        transparent 100%
      ),
      linear-gradient(to right,
        rgba(6,10,18,0.42) 0%,
        transparent 60%
      );
    z-index: 1;
  }

  .kl-hero__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    padding-bottom: clamp(64px, 10svh, 120px);
  }

  .kl-breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    margin-bottom: var(--s-2);
  }

  .kl-breadcrumb__link {
    font-family: var(--mark);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(160,200,240,0.50);
    transition: color 280ms;
  }
  .kl-breadcrumb__link:hover { color: rgba(200,230,255,0.80); }

  .kl-breadcrumb__sep { font-size: 10px; color: rgba(120,165,210,0.28); }

  .kl-breadcrumb__current {
    font-family: var(--mark);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(180,215,248,0.70);
  }

  .kl-hero__tags {
    display: flex;
    align-items: center;
    gap: var(--s-3);
  }

  .kl-hero__tag {
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: rgba(200,220,240,0.40);
  }

  .kl-hero__tag-dot { color: rgba(200,220,240,0.18); }

  .kl-hero__title {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(56px, 9vw, 96px);
    text-wrap: balance;
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: var(--bone);
    margin: 0;
    font-optical-sizing: auto;
  }

  .kl-hero__sub {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(18px, 2vw, 28px);
    color: rgba(196,168,98,0.78);
    margin: 0;
    font-optical-sizing: auto;
  }

  .kl-hero__meta {
    display: flex;
    align-items: center;
    gap: var(--s-4);
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 300;
    color: rgba(200,220,240,0.38);
    padding-top: var(--s-4);
    border-top: 1px solid rgba(200,220,240,0.07);
  }

  .kl-hero__meta-dot { opacity: 0.30; }

  .kl-hero__cta {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    padding: 18px 40px;
    border-radius: var(--r-pill);
    background: var(--gold);
    border: 1px solid var(--gold);
    color: var(--deep);
    transition: background-color 350ms var(--ease), border-color 350ms var(--ease), transform 350ms var(--ease);
    margin-top: var(--s-4);
  }
  .kl-hero__cta:hover {
    background: #B8983A;
    border-color: #B8983A;
    transform: translateY(-1px);
  }



  /* ══════════════════════════════════════════════
     2. INTRODUCTION
     ══════════════════════════════════════════════ */

  .kl-intro {
    background: var(--navy);
    padding-block: clamp(80px, 14svh, 160px);
    border-top: 1px solid rgba(200,220,240,0.04);
  }

  .kl-intro__inner {
    max-width: 840px;
  }

  .kl-intro__text {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(18px, 2vw, 27px);
    line-height: 1.78;
    color: rgba(200,220,240,0.68);
    margin: 0;
    font-optical-sizing: auto;
  }


  /* ══════════════════════════════════════════════
     3. WHY PEOPLE COME
     ══════════════════════════════════════════════ */

  .kl-why {
    background: var(--warm);
  }

  .kl-section-title {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(36px, 5vw, 72px);
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0 0 clamp(56px, 8vw, 96px);
    font-optical-sizing: auto;
    text-wrap: balance;
  }

  .kl-section-title--light {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(36px, 5vw, 72px);
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--bone);
    margin: 0 0 clamp(56px, 8vw, 96px);
    font-optical-sizing: auto;
    text-wrap: balance;
  }

  .kl-why__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(40px, 6vw, 80px) clamp(48px, 8vw, 120px);
  }

  .kl-why__item {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }

  .kl-why__title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(20px, 2vw, 27px);
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0;
    font-optical-sizing: auto;
  }

  .kl-why__body {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 15px;
    line-height: 1.88;
    color: rgba(44,42,38,0.72);
    margin: 0;
    max-width: 42ch;
    text-wrap: pretty;
  }


  /* ══════════════════════════════════════════════
     4. THE JOURNEY
     ══════════════════════════════════════════════ */

  .kl-journey {
    background: var(--warm);
    border-top: 1px solid rgba(44,42,38,0.07);
  }

  .kl-journey__layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: clamp(48px, 8vw, 120px);
    align-items: start;
  }

  .kl-journey__phases {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(44,42,38,0.09);
    border-radius: var(--r-3);
    overflow: hidden;
  }

  .kl-phase {
    padding: clamp(20px, 3vw, 32px) clamp(24px, 4vw, 40px);
    border-bottom: 1px solid rgba(44,42,38,0.07);
    background: rgba(255,255,255,0.42);
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .kl-phase:last-child { border-bottom: none; }

  .kl-phase__label {
    font-family: var(--mark);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(44,42,38,0.35);
    display: block;
  }

  .kl-phase__text {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 15px;
    line-height: 1.78;
    color: rgba(44,42,38,0.62);
    margin: 0;
  }

  .kl-journey__panel {
    position: sticky;
    top: 80px;
    background: rgba(255,255,255,0.58);
    border: 1px solid rgba(44,42,38,0.09);
    border-radius: var(--r-3);
    padding: var(--s-6);
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .kl-panel__title {
    font-family: var(--mark);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(44,42,38,0.32);
    margin: 0;
    padding-bottom: var(--s-4);
    border-bottom: 1px solid rgba(44,42,38,0.07);
  }

  .kl-panel__rows {
    display: flex;
    flex-direction: column;
  }

  .kl-panel__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--s-4);
    padding: var(--s-3) 0;
    border-bottom: 1px solid rgba(44,42,38,0.05);
  }
  .kl-panel__row:last-child { border-bottom: none; }

  .kl-panel__row-label {
    font-family: var(--mark);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(44,42,38,0.38);
    flex-shrink: 0;
  }

  .kl-panel__row-val {
    font-family: var(--serif);
    font-style: italic;
    font-size: 13px;
    color: var(--ink);
    text-align: right;
  }

  .kl-panel__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mark);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 14px 24px;
