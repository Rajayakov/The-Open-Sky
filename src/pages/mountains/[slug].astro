    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--s-5);
  }

  .kl-apply2__title {
    font-family: var(--display);
    font-weight: 200;
    font-size: clamp(48px, 7vw, 96px);
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--bone);
    margin: 0;
    font-optical-sizing: auto;
  }

  .kl-apply2__dates {
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: rgba(200,220,240,0.32);
    margin: 0;
  }

  .kl-apply2__btns {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    width: 100%;
    max-width: 360px;
    margin-top: var(--s-4);
  }

  .kl-apply2__btns .btn {
    justify-content: center;
    width: 100%;
  }

  .kl-apply2__note {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: 13px;
    color: rgba(200,220,240,0.32);
    margin: 0;
    font-optical-sizing: auto;
  }


  /* ══════════════════════════════════════════════
     NAV OVERRIDE — shared for all expedition pages
     ══════════════════════════════════════════════ */

  :global(.nav:not(.nav--scrolled) .nav__wordmark) {
    color: rgba(240,248,255,0.30);
    text-shadow: none;
    pointer-events: none;
  }
  :global(.nav:not(.nav--scrolled) .nav__link) {
    color: rgba(220,235,248,0.90);
    text-shadow: 0 1px 8px rgba(0,0,0,0.40);
  }
  :global(.nav:not(.nav--scrolled) .nav__link:hover) { color: #fff; }
  :global(.nav:not(.nav--scrolled) .nav__link--connect) {
    color: rgba(220,235,248,0.92);
    border-color: rgba(220,235,248,0.28);
  }
  :global(.nav:not(.nav--scrolled) .nav__social) {
    color: rgba(200,220,240,0.55);
  }
  :global(.nav:not(.nav--scrolled) .nav__burger span) { background: rgba(220,235,248,0.88); }


  /* ── Shared section heading (generic template) ── */
  .ej-section-heading {
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(28px, 3.5vw, 52px);
    letter-spacing: -0.025em;
    color: #1E1C18;
    margin: var(--s-4) 0 var(--s-8);
    font-optical-sizing: auto;
    line-height: 1.1;
  }
  .ej-section-heading--light { color: rgba(225,240,255,0.94); }


  /* ══════════════════════════════════════════════
     1. HERO (shared)
     ══════════════════════════════════════════════ */

  .ej-hero {
    position: relative;
    min-height: 88svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .ej-hero__bg {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(to bottom,
        rgba(8,14,24,0.50) 0%,
        rgba(8,14,24,0.08) 25%,
        transparent 48%,
        rgba(6,10,18,0.60) 78%,
        rgba(4,8,14,0.92) 100%
      );
    pointer-events: none;
  }

  .ej-hero__img { position: absolute; inset: 0; z-index: 0; }

  .ej-hero__img-slot { width: 100%; height: 100%; }

  .ej-hero__img-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
  }

  .ej-hero__inner {
    position: relative;
    z-index: 2;
    padding-bottom: clamp(64px, 10svh, 120px);
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }

  .ej-breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    margin-bottom: var(--s-3);
  }

  .ej-breadcrumb__link {
    font-family: var(--mark);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(160,200,240,0.60);
    transition: color 280ms;
  }
  .ej-breadcrumb__link:hover { color: rgba(200,230,255,0.90); }

  .ej-breadcrumb__sep { font-size: 10px; color: rgba(120,165,210,0.35); }

  .ej-breadcrumb__current {
    font-family: var(--mark);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(180,215,248,0.80);
  }

  .ej-hero__meta { display: flex; align-items: center; gap: var(--s-5); }

  .ej-hero__terrain { color: rgba(140,185,230,0.65); letter-spacing: 0.22em; }
  .ej-hero__date-label { color: rgba(120,170,220,0.50); letter-spacing: 0.18em; }

  .ej-hero__title {
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(60px, 11vw, 160px);
    line-height: 0.90;
    letter-spacing: -0.04em;
    color: rgba(240,248,255,0.96);
    margin: 0;
    font-optical-sizing: auto;
    max-width: 10ch;
  }

  .ej-hero__soon {
    font-family: var(--mark);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(140,185,230,0.55);
  }


  /* ── Generic template styles (ej-about through ej-apply) ── */

  .ej-about { background: #EDEAE2; }

  .ej-about__grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: clamp(48px,7vw,88px);
    align-items: start;
  }

  .ej-about__text { display: flex; flex-direction: column; gap: var(--s-5); }
  .ej-about__body { max-width: 52ch; color: rgba(44,42,38,0.58); margin: 0; }

  .ej-meta-panel {
    border: 1px solid rgba(44,42,38,0.12);
    border-radius: var(--r-3);
    padding: var(--s-6);
    background: rgba(255,255,255,0.55);
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
  }

  .ej-meta-panel__title {
    font-family: var(--mark);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(44,42,38,0.38);
    margin: 0;
    padding-bottom: var(--s-4);
    border-bottom: 1px solid rgba(44,42,38,0.08);
  }

  .ej-meta-panel__rows { display: flex; flex-direction: column; gap: 0; }

  .ej-meta-panel__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--s-4);
    padding: var(--s-3) 0;
    border-bottom: 1px solid rgba(44,42,38,0.06);
  }
  .ej-meta-panel__row:last-child { border-bottom: none; }
  .ej-meta-panel__row-label { color: rgba(44,42,38,0.45); }
  .ej-meta-panel__row-val { font-family: var(--serif); font-style: italic; font-size: 14px; color: #2C2A26; text-align: right; }
  .ej-meta-panel__cta { margin-top: var(--s-3); align-self: stretch; justify-content: center; }

  .ej-route {
    position: relative;
    background: radial-gradient(ellipse 60% 50% at 80% 20%, rgba(190,185,170,0.18), transparent 60%), linear-gradient(180deg,#DDD9D0 0%,#D4D0C8 100%);
    overflow: hidden;
  }
  .ej-route__bg { position: absolute; inset: 0; background: radial-gradient(ellipse 70% 40% at 10% 80%, rgba(160,155,140,0.12), transparent 60%); pointer-events: none; }
  .ej-route__phases { position: relative; z-index: 1; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); border: 1px solid rgba(44,42,38,0.10); border-radius: var(--r-3); overflow: hidden; margin-top: var(--s-6); }
  .ej-route__phase { padding: var(--s-6); border-right: 1px solid rgba(44,42,38,0.10); background: rgba(255,255,255,0.35); }
  .ej-route__phase:last-child { border-right: none; }
  .ej-route__phase-label { color: rgba(100,90,78,0.65); display: block; margin-bottom: var(--s-3); }
  .ej-route__phase-body { color: rgba(44,42,38,0.62); margin: 0; }
  .ej-placeholder { margin-top: var(--s-6); padding: var(--s-6); border: 1px dashed rgba(44,42,38,0.18); border-radius: var(--r-2); }
  .ej-placeholder__text { font-family: var(--sans); font-size: 14px; color: rgba(44,42,38,0.40); font-style: italic; margin: 0; }

  .ej-highlights { background: #EDEAE2; }
  .ej-highlights__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--s-6) var(--s-8); }
  .ej-highlight__title { font-family: var(--serif); font-weight: 400; font-size: clamp(20px,2vw,28px); letter-spacing: -0.01em; color: #2C2A26; margin: 0 0 var(--s-3); font-optical-sizing: auto; }
  .ej-highlight__body { color: rgba(44,42,38,0.55); margin: 0; font-style: italic; font-family: var(--serif); font-weight: 300; font-size: 15px; line-height: 1.75; }

  .ej-gallery { background: #EDEAE2; }
  .ej-gallery__grid { display: grid; grid-template-columns: repeat(3, 1fr); grid-auto-rows: 240px; gap: var(--s-3); }
  .ej-gallery__slot { border-radius: var(--r-2); overflow: hidden; position: relative; }
  .ej-gallery__slot::after { content: attr(data-label); position: absolute; left: 10px; bottom: 8px; font-family: ui-monospace,monospace; font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(200,225,248,0.45); }
  .ej-gallery__slot--landscape { grid-column: span 2; }
  .ej-gallery__note { font-family: var(--mark); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(44,42,38,0.30); text-align: center; margin: var(--s-6) 0 0; }

  .ej-testimonials { position: relative; background: radial-gradient(ellipse 60% 50% at 30% 20%, rgba(50,90,140,0.28), transparent 60%), linear-gradient(180deg,#0E1A28 0%,#080F18 100%); overflow: hidden; }
  .ej-testimonials__bg { position: absolute; inset: 0; background: radial-gradient(ellipse 70% 40% at 70% 80%, rgba(30,60,100,0.22), transparent 55%); pointer-events: none; }
  .ej-testimonials__grid { position: relative; z-index: 1; display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--s-6); margin-top: var(--s-6); }
  .ej-testimonial { display: flex; flex-direction: column; gap: var(--s-4); padding: var(--s-6); border: 1px solid rgba(100,150,210,0.12); border-radius: var(--r-3); background: rgba(255,255,255,0.04); }
  .ej-testimonial__quote { font-family: var(--serif); font-style: italic; font-weight: 300; font-size: clamp(15px,1.4vw,18px); line-height: 1.7; color: rgba(200,225,248,0.65); margin: 0; font-optical-sizing: auto; }
  .ej-testimonial__author { display: flex; flex-direction: column; gap: var(--s-1); font-style: normal; }
  .ej-testimonial__name { font-family: var(--mark); font-size: 10px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(160,200,240,0.70); }
  .ej-testimonial__detail { font-family: var(--mark); font-size: 9px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(100,150,210,0.40); }

  .ej-practical { background: #EDEAE2; }
  .ej-practical__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--s-6) var(--s-8); }
  .ej-practical__col-title { font-family: var(--serif); font-weight: 400; font-size: clamp(18px,1.8vw,24px); letter-spacing: -0.01em; color: #2C2A26; margin: 0 0 var(--s-5); font-optical-sizing: auto; }
  .ej-practical__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--s-3); border-top: 1px solid rgba(44,42,38,0.10); padding-top: var(--s-4); }
  .ej-practical__item { display: flex; align-items: baseline; gap: var(--s-3); font-family: var(--sans); font-weight: 300; font-size: 15px; line-height: 1.6; color: rgba(44,42,38,0.60); padding-bottom: var(--s-3); border-bottom: 1px solid rgba(44,42,38,0.06); }
  .ej-practical__mark { color: rgba(166,124,77,0.60); flex-shrink: 0; font-size: 14px; }

  .ej-apply { position: relative; overflow: hidden; }
  .ej-apply__bg { position: absolute; inset: 0; z-index: 0; background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(40,72,128,0.32), transparent 65%), linear-gradient(180deg,#0A1420 0%,#060C16 100%); }
  .ej-apply__inner { position: relative; z-index: 1; max-width: 640px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; text-align: center; gap: var(--s-5); }
  .ej-apply__label { color: rgba(140,185,230,0.55); }
  .ej-apply__heading { font-family: var(--display); font-weight: 500; font-size: clamp(28px,3.5vw,52px); letter-spacing: -0.025em; line-height: 1.12; color: rgba(225,240,255,0.95); margin: 0; font-optical-sizing: auto; }
