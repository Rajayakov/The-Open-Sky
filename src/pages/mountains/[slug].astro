  .kl-tst3__name {
    font-family: var(--serif);
    font-style: italic;
    font-size: 13px;
    color: rgba(200,220,240,0.50);
    line-height: 1.3;
  }

  .kl-tst3__meta {
    font-family: var(--mark);
    font-size: 8px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(200,220,240,0.24);
  }

  .kl-tst3__note {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: 13px;
    color: rgba(200,220,240,0.30);
    margin: clamp(28px,4vw,44px) 0 0;
    text-align: center;
    font-optical-sizing: auto;
  }


  /* ══════════════════════════════════════════════
     S13. FAQ
     ══════════════════════════════════════════════ */

  .kl-faq2 { background: var(--navy); }

  .kl-faq2__inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .kl-faq2__heading {
    font-family: var(--display);
    font-weight: 200;
    font-size: clamp(36px, 4.5vw, 64px);
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--bone);
    margin: clamp(16px,2.5vw,24px) 0 clamp(40px,6vw,56px);
    font-optical-sizing: auto;
  }

  .kl-faq2__list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(200,220,240,0.08);
  }

  .kl-faq2__item {
    border-bottom: 1px solid rgba(200,220,240,0.07);
    overflow: hidden;
  }

  .kl-faq2__btn {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--s-5);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: clamp(18px,2.5vw,28px) 0;
    text-align: left;
  }

  .kl-faq2__q {
    font-family: var(--sans);
    font-weight: 400;
    font-size: clamp(15px, 1.5vw, 17px);
    line-height: 1.5;
    color: var(--bone);
    transition: color 250ms;
  }
  .kl-faq2__btn:hover .kl-faq2__q { color: rgba(240,235,224,0.75); }

  .kl-faq2__icon {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 22px;
    line-height: 1;
    color: rgba(200,220,240,0.28);
    flex-shrink: 0;
    transition: transform 320ms var(--ease), color 250ms;
  }

  .kl-faq2__item.is-open .kl-faq2__icon {
    transform: rotate(45deg);
    color: rgba(200,220,240,0.55);
  }

  .kl-faq2__ans {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 420ms cubic-bezier(0.4,0,0.2,1);
  }

  .kl-faq2__ans-inner { overflow: hidden; }

  .kl-faq2__item.is-open .kl-faq2__ans { grid-template-rows: 1fr; }

  .kl-faq2__ans-text {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 15px;
    line-height: 1.80;
    color: rgba(200,220,240,0.62);
    margin: 0;
    padding-bottom: clamp(18px,2.5vw,28px);
    max-width: 62ch;
    text-wrap: pretty;
  }


  /* ══════════════════════════════════════════════
     S14. APPLY
     ══════════════════════════════════════════════ */

  .kl-apply2 { background: var(--deep); }

  .kl-apply2__inner {
    max-width: 560px;
