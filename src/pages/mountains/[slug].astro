    font-optical-sizing: auto;
  }

  .kl-tst3__quote {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(13px, 1.1vw, 15px);
    line-height: 1.80;
    color: rgba(200,220,240,0.68);
    margin: 0;
    padding: 0;
    text-wrap: pretty;
    font-optical-sizing: auto;
  }

  .kl-tst3__attr {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: var(--s-4);
