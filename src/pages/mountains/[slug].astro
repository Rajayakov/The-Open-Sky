---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { journeys, getJourney, pastExpeditions } from '../../data/mountains';
import '../../styles/global.css';

export function getStaticPaths() {
  return journeys.map((j) => ({ params: { slug: j.slug } }));
}

const { slug } = Astro.params;
const journey = getJourney(slug!);
if (!journey) return Astro.redirect('/mountains');

const isUpcoming = journey.status === 'upcoming';
const isSoon     = journey.status === 'soon';
const isKailash  = journey.slug === 'kailash-2026';

const pastTwo = pastExpeditions.slice(0, 2);

const klFaq = [
  {
    q: 'What level of physical fitness is required?',
    a: 'You should be able to walk 6–8 hours daily at altitudes between 4,800 and 5,600 metres, carrying a light day pack. The kora covers approximately 52 kilometres over three days. No technical climbing is involved. Cardiovascular fitness matters more than mountain experience.',
  },
  {
    q: 'What happens with altitude sickness?',
    a: 'Two acclimatisation days are built into the programme. Emergency oxygen is carried throughout the kora. We hold safety above all other considerations and will not continue if a participant cannot safely do so.',
  },
  {
    q: 'How do Tibet visas work?',
    a: 'Tibet requires a Tibet Travel Permit in addition to a Chinese visa. We arrange all documentation through our on-the-ground partners. Full details and costs are explained at the point of application.',
  },
  {
    q: 'What is the payment schedule?',
    a: 'A deposit of $700 USD secures your place. The remaining balance is due 60 days before departure. Full payment details are shared during the initial conversation.',
  },
  {
    q: 'What if I need to cancel?',
    a: 'Cancellation policy is standard for high-altitude expeditions of this complexity. Full details are shared at the point of application. We recommend travel insurance that covers cancellation.',
  },
  {
    q: 'Will there be time alone, or is everything guided?',
    a: 'There is deliberate space for solitude throughout, particularly during the kora itself. The group process and ceremonies are integral, but so is unstructured time with the mountain. The balance is held by Yakov.',
  },
];

const klGiveCards = [
  { title: 'Clarity',       body: 'Arrives not as insight but as a quieting. You understand what matters without having to think about it.' },
  { title: 'Stillness',     body: 'The kind that cannot be reproduced at home. A reference point your body will remember when ordinary noise returns.' },
  { title: 'Perspective',   body: 'Distance from what seemed large. Altitude does this literally — and then something else does it more permanently.' },
  { title: 'Direction',     body: 'Not answers, but a deepened ability to hear your own questions. The mountain does not tell you what to do.' },
  { title: 'Vitality',      body: 'Your body will have done something real. The tiredness that follows is the earned kind.' },
  { title: 'A fixed point', body: 'An interior place you return to for years. People describe this a long time after the journey ends.' },
];

const klRecogQuestions = [
  'A feeling that what you are building is important, but that something equally important is being missed.',
  'A need for something that cannot be purchased or scheduled — something the usual solutions do not reach.',
  'A recurring pull toward significant terrain, long walks, and the kind of silence that asks something of you.',
  'The sense that your next step will not be found by thinking harder, but by going somewhere that demands more.',
  'A readiness to be changed by an experience, not merely moved by it.',
];
---

<Base
  title={isKailash
    ? 'Kailash 2026 — Sacred Expedition — The Open Sky'
    : `${journey.title} — Mountains — The Open Sky`}
  description={journey.description}
>
  <Nav />
  <main class:list={[isKailash && 'kl-land']}>

    <!-- ══════════════════════════════════════════
         1. HERO — untouched for all slugs
         ══════════════════════════════════════════ -->

    <section class="ej-hero" aria-label={journey.title}>
      <div class="ej-hero__bg" aria-hidden="true"></div>
      <div class="ej-hero__img" aria-hidden="true">
        {journey.heroImage ? (
          <img
            class="ej-hero__img-photo"
            src={journey.heroImage}
            alt={journey.title}
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        ) : (
          <div class="ej-hero__img-slot" style={`background: ${journey.bg};`}></div>
        )}
      </div>
      <div class="ej-hero__inner frame">
        <nav class="ej-breadcrumb reveal" aria-label="Breadcrumb">
          <a href="/mountains" class="ej-breadcrumb__link">Mountains</a>
          <span class="ej-breadcrumb__sep" aria-hidden="true">→</span>
          <span class="ej-breadcrumb__current">{journey.title}</span>
        </nav>
        <div class="ej-hero__meta reveal d1">
          <span class="t-label ej-hero__terrain">{journey.terrain}</span>
          {journey.dateShort && journey.dateShort !== 'TBA' && (
            <span class="t-label ej-hero__date-label">{journey.dateShort}</span>
          )}
        </div>
        <h1 class="ej-hero__title reveal d2">{journey.title}</h1>
        {isUpcoming && (
          <a href="#apply" class="btn btn--ghost-d ej-hero__cta reveal d3">Apply for this expedition</a>
        )}
        {isSoon && (
          <span class="ej-hero__soon reveal d3">Dates to be announced</span>
        )}
      </div>
    </section>

    {isKailash ? (

      /* ═══════════════════════════════════════════════════
         KAILASH 2026 — FULL LANDING (Sections 2–14)
         ═══════════════════════════════════════════════════ */
      <>

        <!-- ══════════════════════════════════════════
             2. PERSONAL LETTER
             ══════════════════════════════════════════ -->

        <section class="kl-letter section" aria-label="A letter from Yakov">
          <div class="frame">
            <div class="kl-letter__inner">
              <span class="t-label t-label--warm kl-letter__label reveal">A letter from Yakov</span>
              <!-- LETTER_PLACEHOLDER -->
              <p class="kl-letter__para reveal d1">
                I have been to Kailash once. That was enough to understand that once is
                not the point. The mountain does not reveal itself in full on any single
                circumambulation. What it gives you instead is a direction — and the
                clarity to recognise it.
              </p>
              <p class="kl-letter__para reveal d2">
                I am bringing a small group in September 2026. Six people, ten days,
                one of the most demanding and most revered landscapes on earth.
                There will be altitude, distance, silence, and ceremony. There will also
                be a quality of interior encounter that I have not found anywhere else.
              </p>
              <p class="kl-letter__para reveal d3">
                If you are reading this and something in you recognises it — write.
                We will speak, and you will know whether this is your moment.
              </p>
              <p class="kl-letter__sig reveal d4">— Yakov Rajuna</p>
            </div>
          </div>
          <div class="kl-letter__rule" aria-hidden="true"></div>
        </section>


        <!-- ══════════════════════════════════════════
             3. RECOGNITION
             ══════════════════════════════════════════ -->

        <section class="kl-recog section" aria-label="Perhaps you recognise this">
          <div class="frame kl-recog__frame">

            <div class="kl-recog__left">
              <span class="t-label t-label--warm reveal">Recognition</span>
              <h2 class="kl-recog__heading reveal d1">Perhaps you<br/>recognise this.</h2>
            </div>

            <div class="kl-recog__right">
              <div class="kl-recog__questions">
                {klRecogQuestions.map((q, i) => (
                  <p class={`kl-recog__q reveal d${(i % 3) + 1}`}>{q}</p>
                ))}
              </div>
              <p class="kl-recog__close reveal d2">
                If any of this is familiar, you are in the right place.
              </p>
            </div>

          </div>
        </section>


        <!-- ══════════════════════════════════════════
             4. WHY KAILASH
             ══════════════════════════════════════════ -->

        <section class="kl-why2 section" aria-label="Why Kailash">
          <div class="frame kl-why2__frame">

            <div class="kl-why2__content">
              <span class="t-label t-label--warm reveal">The Mountain</span>
              <h2 class="kl-why2__heading reveal d1">Why Kailash.</h2>
              <p class="kl-why2__body reveal d2">
                Kailash is considered the axis of the world across four living traditions:
                Hindu, Buddhist, Jain, and Bonpo. It has never been summited. Not for lack
                of attempt — but because every tradition that holds it sacred has chosen not to.
                The mountain is approached through circumambulation, not conquest.
              </p>
              <p class="kl-why2__body reveal d3">
                The kora — three days of walking around the mountain at altitudes above
                5,000 metres — is one of the most ancient pilgrimage routes on earth.
                The terrain surrounding Kailash carries a quality that is very difficult
                to translate into language. People who have been there will understand
                immediately what this means.
              </p>
              <p class="kl-why2__body reveal d4">
                What the mountain gives is not comfort or beauty in any easy sense.
                It gives scale — interior and exterior simultaneously. Most people return
                quieter. More certain of what matters. Changed in ways that take months
                to fully understand.
              </p>
            </div>

            <div class="kl-why2__visual reveal d2">
              {journey.heroImage ? (
                <img
                  class="kl-why2__img"
                  src={journey.heroImage}
                  alt="Mount Kailash, Tibet"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="kl-img-slot" style={`background: ${journey.bg}`}></div>
              )}
            </div>

          </div>
        </section>


        <!-- ══════════════════════════════════════════
             5. WHAT THIS JOURNEY MAY GIVE YOU
             ══════════════════════════════════════════ -->

        <section class="kl-give section" aria-label="What this journey may give you">
          <div class="frame">
            <span class="t-label t-label--warm reveal">Gifts of the journey</span>
            <h2 class="kl-give__heading reveal d1">What this journey<br/>may give you.</h2>

            <div class="kl-give__grid">
              {klGiveCards.map((card, i) => (
                <div class={`kl-give__card reveal d${(i % 3) + 1}`}>
                  <h3 class="kl-give__card-title">{card.title}</h3>
                  <p class="kl-give__card-body">{card.body}</p>
                </div>
              ))}
            </div>
          </div>
        </section>


        <!-- ══════════════════════════════════════════
             6. THE ROUTE — Programme by day
             ══════════════════════════════════════════ -->

        <section class="kl-route section" aria-label="The route">
          <div class="frame">
            <span class="t-label t-label--warm reveal">Programme</span>
            <h2 class="kl-route__heading reveal d1">The Route.</h2>

            <div class="kl-route__timeline" role="list">
              {(journey.structure ?? []).map((phase, i) => (
                <div class={`kl-route__row reveal d${(i % 2) + 1}`} role="listitem">
                  <span class="kl-route__label">{phase.phase}</span>
                  <div class="kl-route__track" aria-hidden="true">
                    <span class="kl-route__dot"></span>
                  </div>
                  <p class="kl-route__desc">{phase.description}</p>
                </div>
              ))}
            </div>
          </div>
        </section>


        <!-- ══════════════════════════════════════════
             7. INCLUDED / NOT INCLUDED
             ══════════════════════════════════════════ -->

        <section class="kl-incl section" aria-label="What is included">
          <div class="frame">
            <h2 class="kl-incl__heading reveal">Included.</h2>

            <div class="kl-incl__cols">

              <div class="kl-incl__col reveal d1">
                <p class="kl-incl__col-title">In the expedition</p>
                <ul class="kl-incl__list" role="list">
                  {(journey.included ?? []).map((item) => (
                    <li class="kl-incl__item">
                      <span class="kl-incl__check kl-incl__check--yes" aria-hidden="true">✓</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="kl-incl__col reveal d2">
                <p class="kl-incl__col-title">Arranged separately</p>
                <ul class="kl-incl__list" role="list">
                  {(['International flights', 'Travel insurance (mandatory)', 'Personal trekking equipment', 'Visa fees'] as const).map((item) => (
                    <li class="kl-incl__item kl-incl__item--other">
                      <span class="kl-incl__check" aria-hidden="true">✓</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>

            </div>
          </div>
        </section>


        <!-- ══════════════════════════════════════════
             8. INVESTMENT
             ══════════════════════════════════════════ -->

        <section class="kl-invest section" aria-label="Investment">
          <div class="frame">
            <div class="kl-invest__inner">
              <span class="t-label t-label--warm reveal">Investment</span>
              <p class="kl-invest__price reveal d1">$3,500 <span class="kl-invest__currency">USD</span></p>
              <p class="kl-invest__per reveal d2">per person · all-inclusive</p>

              <div class="kl-invest__metas reveal d2">
                <p class="kl-invest__meta">Deposit to reserve <span>$700 USD</span></p>
                <p class="kl-invest__meta">Group size <span>Max 6 people</span></p>
                <p class="kl-invest__meta">Places remaining <span>4</span></p>
              </div>

              <p class="kl-invest__scarcity reveal d3">
                When the current allocation fills, pricing increases.
              </p>

              <a href="#apply" class="btn btn--warm kl-invest__cta reveal d4">Apply for your place</a>
            </div>
          </div>
        </section>


        <!-- ══════════════════════════════════════════
             9. FOR WHOM / NOT FOR WHOM
             ══════════════════════════════════════════ -->

        <section class="kl-whom section" aria-label="Who this journey is for">
          <div class="frame kl-whom__frame">

            <div class="kl-whom__col">
              <p class="kl-whom__col-title reveal">This journey is for you if</p>
              <ul class="kl-whom__list" role="list">
                {(journey.forWhom ?? []).map((item, i) => (
                  <li class={`kl-whom__item reveal d${(i % 2) + 1}`}>
                    <span class="kl-whom__mark" aria-hidden="true">—</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="kl-whom__col kl-whom__col--not">
              <p class="kl-whom__col-title reveal">This journey is not for you if</p>
              <ul class="kl-whom__list" role="list">
                {([
                  'You expect comfort over meaning',
                  'Physical challenge is something you avoid rather than meet',
                  'You are looking for a group tour with a fixed programme',
                ] as const).map((item, i) => (
                  <li class={`kl-whom__item reveal d${(i % 2) + 1}`}>
                    <span class="kl-whom__mark" aria-hidden="true">—</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>

          </div>
        </section>


        <!-- ══════════════════════════════════════════
             10. YAKOV — THE GUIDE
             ══════════════════════════════════════════ -->

        <section class="kl-gd section" aria-label="About the guide">
          <div class="frame kl-gd__frame">

            <div class="kl-gd__photo reveal d1" role="img" aria-label="Yakov Rajuna"></div>

            <div class="kl-gd__content">
              <span class="t-label t-label--warm reveal">Your guide</span>
              <h2 class="kl-gd__name reveal d1">Yakov Rajuna</h2>

              <div class="kl-gd__stats reveal d2">
                {([
                  { num: '20+',    label: 'Years' },
                  { num: '350+',   label: 'Ceremonies' },
                  { num: '3,500+', label: 'Participants' },
                ] as const).map((s) => (
                  <div class="kl-gd__stat">
                    <span class="kl-gd__stat-num">{s.num}</span>
                    <span class="kl-gd__stat-label">{s.label}</span>
                  </div>
                ))}
              </div>

              <p class="kl-gd__roles reveal d2">Guide · Healer · Teacher · Expedition Leader</p>

              <p class="kl-gd__quote reveal d3">
                Every expedition is led by Yakov personally. No assistants. No proxies.
                This is why the groups are small.
              </p>

              <a href="/about" class="btn btn--ghost-d kl-gd__link reveal d4">Full biography →</a>
            </div>

          </div>
        </section>


        <!-- ══════════════════════════════════════════
             11. PAST EXPEDITIONS
             ══════════════════════════════════════════ -->

        <section class="kl-past section" aria-label="Past expeditions">
          <div class="frame">
            <span class="t-label t-label--warm reveal">Precedent</span>
            <h2 class="kl-past__heading reveal d1">Where we have been.</h2>

            <div class="kl-past__grid">
              {([
                { name: 'Mardi Himal',  region: 'Nepal', meta: '2025 · 12 participants', bg: pastTwo[0]?.bg ?? 'linear-gradient(160deg,#7898B8,#18283A)' },
                { name: 'Himalayas',    region: 'Nepal', meta: '2024',                   bg: pastTwo[1]?.bg ?? 'linear-gradient(160deg,#A0B4C8,#1E2C3A)' },
              ] as const).map((card, i) => (
                <div class={`kl-past__card reveal d${i + 1}`}>
                  <div class="kl-past__card-bg" style={`background: ${card.bg}`} aria-hidden="true"></div>
                  <div class="kl-past__card-content">
                    <p class="kl-past__card-name">{card.name}</p>
                    <p class="kl-past__card-meta">{card.region} · {card.meta}</p>
                  </div>
                </div>
              ))}
            </div>

            <p class="kl-past__note reveal">
              Kailash is a new destination for this group. The guide is not.
            </p>
          </div>
        </section>


        <!-- ══════════════════════════════════════════
             12. TESTIMONIALS
             ══════════════════════════════════════════ -->

        <section class="kl-tst3 section" aria-label="From participants">
          <div class="frame">
            <span class="t-label t-label--warm reveal">From participants</span>
            <h2 class="kl-tst3__heading reveal d1">What people say.</h2>

            <div class="kl-tst3__grid">
              {([
                {
                  quote: 'I returned quieter. More certain of what matters. The mountain does not explain itself, and neither does the change.',
                  name:  'Elena K.',
                  meta:  'Moscow · Mardi Himal 2025',
                },
                {
                  quote: 'Yakov holds the space without filling it. That quality is rare. The mountains do the work. He ensures you can receive it.',
                  name:  'David M.',
                  meta:  'Berlin · Georgian Highlands 2024',
                },
                {
                  quote: 'Not transformed in any dramatic way. Clarified. Like something blurry for years finally came into focus.',
                  name:  'Maria T.',
                  meta:  'Tbilisi · Pontic Alps 2024',
                },
              ] as const).map((t, i) => (
                <figure class={`kl-tst3__card reveal d${i + 1}`}>
                  <span class="kl-tst3__glyph" aria-hidden="true">"</span>
                  <blockquote class="kl-tst3__quote">{t.quote}</blockquote>
                  <figcaption class="kl-tst3__attr">
                    <span class="kl-tst3__name">{t.name}</span>
                    <span class="kl-tst3__meta">{t.meta}</span>
                  </figcaption>
                </figure>
              ))}
            </div>

            <p class="kl-tst3__note reveal">
              These journeys were different from Kailash in terrain. The inner process is the same.
            </p>
          </div>
        </section>


        <!-- ══════════════════════════════════════════
             13. FAQ
             ══════════════════════════════════════════ -->

        <section class="kl-faq2 section" aria-label="Questions">
          <div class="frame">
            <div class="kl-faq2__inner">
              <span class="t-label t-label--warm reveal">Questions</span>
              <h2 class="kl-faq2__heading reveal d1">Before you write.</h2>

              <div class="kl-faq2__list">
                {klFaq.map((item, i) => (
                  <div class={`kl-faq2__item reveal d${(i % 3) + 1}`}>
                    <button class="kl-faq2__btn" type="button" aria-expanded="false">
                      <span class="kl-faq2__q">{item.q}</span>
                      <span class="kl-faq2__icon" aria-hidden="true">+</span>
                    </button>
                    <div class="kl-faq2__ans" role="region">
                      <div class="kl-faq2__ans-inner">
                        <p class="kl-faq2__ans-text">{item.a}</p>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </section>


        <!-- ══════════════════════════════════════════
             14. FINAL APPLY
             ══════════════════════════════════════════ -->

        <section class="kl-apply2 section" id="apply" aria-label="Apply">
          <div class="frame">
            <div class="kl-apply2__inner">
              <span class="t-label t-label--warm reveal">Apply</span>
              <h2 class="kl-apply2__title reveal d1">Kailash.</h2>
              <p class="kl-apply2__dates reveal d2">
                September 20–30, 2026 · Tibet · 4 places remaining
              </p>

              <div class="kl-apply2__btns reveal d3">
                <a href="/connect?from=kailash-2026" class="btn btn--warm">Apply for your place</a>
                <a
                  href="https://t.me/yakovrajuna"
                  class="btn btn--ghost-d"
                  target="_blank"
                  rel="noopener noreferrer"
                >Write in Telegram</a>
              </div>

              <p class="kl-apply2__note reveal d4">Yakov reads every message himself.</p>
            </div>
          </div>
        </section>

      </>

    ) : (

      /* ═══════════════════════════════════════════════════
         GENERIC EXPEDITION TEMPLATE (all other slugs)
         ═══════════════════════════════════════════════════ */
      <>

        <!-- 2. ABOUT -->
        <section class="ej-about section frame" aria-label="About the journey">
          <div class="ej-about__grid">
            <div class="ej-about__text reveal">
              <span class="t-label t-label--warm">About This Journey</span>
              <h2 class="ej-section-heading">{journey.description}</h2>
              <p class="t-body ej-about__body">
                [Detailed description of the expedition — the landscape, the physical experience, the inner dimension. To be written.]
              </p>
              <p class="t-body ej-about__body">
                [What makes this mountain significant. What participants can expect to encounter — physically, emotionally, and in terms of the group process.]
              </p>
            </div>
            <div class="ej-about__sidebar reveal d2">
              <div class="ej-meta-panel">
                <h3 class="ej-meta-panel__title">Expedition Details</h3>
                <div class="ej-meta-panel__rows">
                  {[
                    { label: 'Dates',       value: journey.date },
                    { label: 'Location',    value: journey.location },
                    { label: 'Duration',    value: journey.duration },
                    ...(journey.altitude   ? [{ label: 'Altitude',   value: journey.altitude   }] : []),
                    ...(journey.groupSize  ? [{ label: 'Group size', value: journey.groupSize  }] : []),
                    ...(journey.difficulty ? [{ label: 'Difficulty', value: journey.difficulty }] : []),
                  ].map(row => (
                    <div class="ej-meta-panel__row">
                      <span class="t-label ej-meta-panel__row-label">{row.label}</span>
                      <span class="ej-meta-panel__row-val">{row.value}</span>
                    </div>
                  ))}
                </div>
                {isUpcoming && (
                  <a href="#apply" class="btn btn--warm ej-meta-panel__cta">Express Interest</a>
                )}
              </div>
            </div>
          </div>
        </section>

        <!-- 3. ROUTE -->
        <section class="ej-route section" aria-label="Route">
          <div class="frame">
            <span class="t-label t-label--warm reveal">The Route</span>
            <h2 class="ej-section-heading reveal d1">Day by day.</h2>
            {(journey.structure ?? []).length > 0 ? (
              <div class="ej-route__phases">
                {(journey.structure ?? []).map((phase, i) => (
                  <div class={`ej-route__phase reveal d${(i % 3) + 1}`}>
                    <span class="t-label ej-route__phase-label">{phase.phase}</span>
                    <p class="t-body ej-route__phase-body">{phase.description}</p>
                  </div>
                ))}
              </div>
            ) : (
              <div class="ej-placeholder reveal d1">
                <p class="ej-placeholder__text">Route details to be announced.</p>
              </div>
            )}
          </div>
          <div class="ej-route__bg" aria-hidden="true"></div>
        </section>

        <!-- 4. HIGHLIGHTS -->
        <section class="ej-highlights section frame" aria-label="Highlights">
          <span class="t-label t-label--warm reveal">Highlights</span>
          <h2 class="ej-section-heading reveal d1">What this journey offers.</h2>
          <div class="ej-highlights__grid">
            {[
              { title: 'The Landscape', body: '[Description of the specific landscape and what it demands and offers.]' },
