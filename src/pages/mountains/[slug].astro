  /* ══════════════════════════════════════════════
     S11. PAST EXPEDITIONS
     ══════════════════════════════════════════════ */

  .kl-past { background: var(--navy); }

  .kl-past__heading {
    font-family: var(--display);
    font-weight: 200;
    font-size: clamp(36px, 4.5vw, 64px);
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--bone);
    margin: clamp(16px,2.5vw,24px) 0 clamp(40px,6vw,64px);
    font-optical-sizing: auto;
  }

  .kl-past__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(16px, 2.5vw, 28px);
  }

  .kl-past__card {
    position: relative;
    aspect-ratio: 16/10;
    border-radius: 12px;
    overflow: hidden;
  }

  .kl-past__card-bg {
    position: absolute;
    inset: 0;
    filter: saturate(0.75) brightness(0.72);
    transition: filter 500ms;
  }
  .kl-past__card:hover .kl-past__card-bg {
    filter: saturate(0.88) brightness(0.82);
  }

  .kl-past__card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: clamp(20px,3vw,32px);
    background: linear-gradient(to top, rgba(8,14,24,0.88) 0%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }

  .kl-past__card-name {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(22px, 2.5vw, 36px);
    letter-spacing: -0.02em;
    color: var(--bone);
    margin: 0;
    font-optical-sizing: auto;
  }

  .kl-past__card-meta {
    font-family: var(--mark);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(200,220,240,0.45);
    margin: 0;
  }

  .kl-past__note {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: 14px;
    line-height: 1.6;
    color: rgba(200,220,240,0.38);
    margin: clamp(28px,4vw,44px) 0 0;
    text-align: center;
    font-optical-sizing: auto;
  }


  /* ══════════════════════════════════════════════
     S12. TESTIMONIALS
     ══════════════════════════════════════════════ */

  .kl-tst3 { background: var(--deep); }

  .kl-tst3__heading {
    font-family: var(--display);
    font-weight: 200;
    font-size: clamp(36px, 4.5vw, 64px);
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--bone);
    margin: clamp(16px,2.5vw,24px) 0 clamp(40px,6vw,64px);
    font-optical-sizing: auto;
  }

  .kl-tst3__grid {
