---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import UpcomingSection from '../components/UpcomingSection.astro';
import ProductGrid from '../components/ProductGrid.astro';
import MentorshipBanner from '../components/MentorshipBanner.astro';
import MusicSection from '../components/MusicSection.astro';
import ConnectSection from '../components/ConnectSection.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Base
  title="The Open Sky — by Yakov Rajuna"
  description="Retreats in sacred landscapes. Mountain journeys. Online programs. Personal mentorship. An ecosystem of transformational experiences founded by Yakov Rajuna."
>
  <Nav />
  <main>
    <div class="home-gradient">
      <Hero />
      <UpcomingSection />
      <ProductGrid />
      <MentorshipBanner />
      <MusicSection />
      <ConnectSection />
    </div>
  </main>
  <Footer />
</Base>

<style>
  /* Continuous atmospheric gradient — open sky through sunrise to dusk */
  .home-gradient {
    background: linear-gradient(
      180deg,
      #E8F2F8  0%,    /* pale morning sky */
      #EAF0F2  1.2%,  /* sky settling */
      #EEEbE3  2.8%,  /* sky into warm neutral */
      #F1EBD9  4.5%,  /* warm entering */
      #F4EDD8  7%,    /* warm ivory */
      #F2E9CE 11%,
      #EDDABB 18%,
      #EAD2A8 24%,
      #E8D3A0 30%,
      #E4CA8E 36%,
      #DDBC7A 43%,
      #D8B46A 49%,
      #D0A658 55%,
      #C89444 61%,
      #B88438 66%,
      #A87230 71%,
      #8E6020 76%,
      #785018 81%,
      #5E3C10 86%,
      #4A2E10 90%,
      #3A2210 94%,
      #2E1A0C 97%,
      #261408 100%
    );
  }
</style>
