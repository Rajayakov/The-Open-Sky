---
---

<section class="ecosystem dark section" aria-label="The ecosystem">
  <div class="frame">

    <div class="ecosystem__inner reveal">

      <div class="ecosystem__text">
        <span class="t-label t-label--gold ecosystem__label">The ecosystem</span>
        <p class="ecosystem__body">
          Five years. Twelve countries. A quiet, serious community of people
          who take their inner life as seriously as their outer one.
        </p>
        <a href="/connect" class="ecosystem__contact">Write directly →</a>
      </div>

      <nav class="ecosystem__socials" aria-label="Social channels">
        <a href="https://t.me/yakovrajuna" class="ecosystem__social" target="_blank" rel="noopener" aria-label="Telegram — 340+ members">
          <div class="ecosystem__icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M21.198 2.433a2.242 2.242 0 0 0-1.022.215L3.29 9.865c-1.392.54-1.386 1.295-.253 1.629l4.47 1.395 10.35-6.528c.488-.298.937-.14.569.186L9.568 15.366l-.32 4.576c.471 0 .68-.217.938-.467l2.253-2.189 4.68 3.455c.862.476 1.482.23 1.696-.8l3.07-14.43c.313-1.253-.476-1.821-1.687-1.078z" fill="currentColor"/>
            </svg>
          </div>
          <span class="ecosystem__platform">Telegram</span>
          <span class="ecosystem__count">340+</span>
        </a>
        <a href="https://youtube.com/@yakovrajuna" class="ecosystem__social" target="_blank" rel="noopener" aria-label="YouTube">
          <div class="ecosystem__icon">
            <svg width="20" height="16" viewBox="0 0 22 16" fill="none" aria-hidden="true">
              <rect x="0.8" y="0.8" width="20.4" height="14.4" rx="3.8" stroke="currentColor" stroke-width="1.5"/>
              <path d="M9 4.5l6 3.5-6 3.5V4.5z" fill="currentColor"/>
            </svg>
          </div>
          <span class="ecosystem__platform">YouTube</span>
        </a>
        <a href="https://instagram.com/yakovrajuna" class="ecosystem__social" target="_blank" rel="noopener" aria-label="Instagram">
          <div class="ecosystem__icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5.5" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor"/>
            </svg>
          </div>
          <span class="ecosystem__platform">Instagram</span>
        </a>
      </nav>

    </div>

  </div>
</section>

<style>
  .ecosystem {
    background: transparent;
    padding-block: clamp(80px, 12vw, 140px);
  }

  .ecosystem__inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: clamp(40px, 8vw, 96px);
  }

  .ecosystem__text {
    display: flex;
    flex-direction: column;
    gap: var(--s-6);
    max-width: 48ch;
  }

  .ecosystem__label { display: block; }

  .ecosystem__body {
    font-family: var(--sans);
    font-weight: 300;
    font-size: clamp(15px, 1.4vw, 18px);
    line-height: 1.85;
    color: rgba(237, 224, 200, 0.52);
    margin: 0;
  }

  .ecosystem__contact {
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(237, 224, 200, 0.40);
    transition: color 260ms ease;
    align-self: flex-start;
  }
  .ecosystem__contact:hover { color: var(--honey); }

  /* Social icons — small, understated, elegant */
  .ecosystem__socials {
    display: flex;
    align-items: center;
    gap: clamp(32px, 4vw, 52px);
    flex-shrink: 0;
    padding-bottom: 4px;
  }

  .ecosystem__social {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-3);
    opacity: 0.40;
    transition: opacity 320ms ease;
    text-decoration: none;
  }
  .ecosystem__social:hover { opacity: 0.85; }

  .ecosystem__icon {
    color: rgba(237, 224, 200, 0.80);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
  }

  .ecosystem__platform {
    font-family: var(--mark);
    font-size: 8.5px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(237, 224, 200, 0.60);
    display: block;
  }

  .ecosystem__count {
    font-family: var(--mark);
    font-size: 7.5px;
    letter-spacing: 0.12em;
    color: rgba(237, 224, 200, 0.30);
    display: block;
    text-align: center;
  }

  @media (max-width: 640px) {
    .ecosystem__inner { flex-direction: column; align-items: flex-start; gap: var(--s-9); }
    .ecosystem__socials { gap: var(--s-8); }
  }
</style>
