---
---

<section class="featured section--lg" id="experience" aria-label="Featured experience">
  <div class="featured__bg" aria-hidden="true">
    <div class="featured__orb"></div>
  </div>

  <div class="frame">
    <div class="featured__inner">

      <!-- Image -->
      <div class="featured__media reveal">
        <div
          class="img-slot img-slot--tall featured__img"
          data-label="Retreat · Mountain landscape"
          style="background:
            radial-gradient(ellipse 60% 50% at 40% 30%, rgba(255,228,175,0.6), transparent 60%),
            linear-gradient(175deg, #C19763 0%, #8E6B40 40%, #4A371F 100%);"
          aria-hidden="true"
        ></div>
      </div>

      <!-- Content -->
      <div class="featured__content">
        <span class="t-label t-label--warm reveal">Featured retreat</span>

        <h2 class="featured__title reveal d1">
          Five days<br />
          <em>in the mountains.</em>
        </h2>

        <div class="ornament reveal d2"></div>

        <p class="t-lede featured__lede reveal d2">
          A small group. A specific mountain range. Five days of walking, ceremony, and the kind of conversation that only happens when people are tired enough to be honest.
        </p>

        <div class="featured__details reveal d3">
          <div class="featured__detail">
            <span class="t-label">Duration</span>
            <span class="featured__detail-val">5 Days · 4 Nights</span>
          </div>
          <div class="featured__detail">
            <span class="t-label">Format</span>
            <span class="featured__detail-val">Expedition · Ceremony · Group</span>
          </div>
          <div class="featured__detail">
            <span class="t-label">Size</span>
            <span class="featured__detail-val">6–10 people</span>
          </div>
          <div class="featured__detail">
            <span class="t-label">Next</span>
            <span class="featured__detail-val">Autumn 2026</span>
          </div>
        </div>

        <div class="featured__actions reveal d4">
          <a href="/retreats/mountain-autumn-2026" class="btn btn--warm">Learn more</a>
          <a href="/connect" class="btn-text">Express interest</a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .featured {
    position: relative;
    background: var(--bone);
    overflow: hidden;
  }

  .featured__bg {
    position: absolute;
    inset: 0;
    background: var(--bg-deep);
    z-index: 0;
  }

  .featured__orb {
    position: absolute;
    right: -10vw; bottom: -20vw;
    width: 60vw; height: 60vw;
    max-width: 700px; max-height: 700px;
    border-radius: 50%;
    background: var(--orb);
    opacity: 0.3;
    filter: blur(6px);
  }

  .featured__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(40px, 7vw, 90px);
    align-items: start;
  }

  .featured__img {
    width: 100%;
    aspect-ratio: 3/4;
    border-radius: var(--r-2);
  }

  .featured__content {
    display: flex;
    flex-direction: column;
    padding-top: var(--s-5);
  }

  .featured__title {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(38px, 5vw, 72px);
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: var(--earth);
    margin: var(--s-4) 0 0;
    max-width: 12ch;
  }
  .featured__title em {
    font-style: italic;
    color: var(--honey);
    display: block;
  }

  .ornament { margin: var(--s-6) 0; }

  .featured__lede {
    margin-bottom: var(--s-6);
    max-width: 42ch;
  }

  .featured__details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-4) var(--s-6);
    padding-block: var(--s-5);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin-bottom: var(--s-6);
  }

  .featured__detail {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }

  .featured__detail-val {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: 16px;
    color: var(--earth);
    line-height: 1.4;
  }

  .featured__actions {
    display: flex;
    align-items: center;
    gap: var(--s-5);
    flex-wrap: wrap;
  }

  @media (max-width: 860px) {
    .featured__inner { grid-template-columns: 1fr; }
    .featured__img { aspect-ratio: 16/9; }
  }
</style>
