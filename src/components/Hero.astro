---
---

<section class="hero" aria-label="Hero">

  <div class="hero__bg" aria-hidden="true">
    <img class="hero__img" src="/images/hero-bg.jpg" alt="" />
    <!-- No overlay — original photograph brightness preserved -->
  </div>

  <!-- Brand mark — suspended in the open sky, beneath the sun -->
  <div class="hero__mark reveal">
    <p class="hero__name">The Open Sky</p>
    <p class="hero__sub">by Yakov Rajuna</p>
    <p class="hero__tagline">The Living Field of Transformation</p>
  </div>

</section>

<style>
  .hero {
    position: relative;
    min-height: 95svh;
    overflow: hidden;
  }

  /* ─── Background — photograph untouched ────────── */

  .hero__bg {
    position: absolute; inset: 0; z-index: 0;
  }

  .hero__img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 32%;
    display: block;
    filter: none;
  }

  /* ─── Brand Mark — floating in open sky ────────── */

  .hero__mark {
    position: absolute;
    top: 14%;
    right: clamp(24px, 4vw, 64px);
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: flex-end;
    text-align: right;
  }

  .hero__name {
    font-family: var(--mark);
    font-size: clamp(32px, 4.2vw, 60px);
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    white-space: nowrap;
    color: rgba(255, 255, 255, 0.98);
    margin: 0;
    line-height: 1;
    text-shadow: 0 0 12px rgba(255, 255, 255, 0.25);
  }

  .hero__sub {
    font-family: var(--sans);
    font-size: clamp(14px, 1.2vw, 18px);
    font-weight: 300;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    line-height: 1;
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.20);
  }

  .hero__tagline {
    font-family: var(--mark);
    font-size: clamp(9px, 0.82vw, 12px);
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
    margin: 4px 0 0;
    line-height: 1;
    text-shadow: 0 0 6px rgba(255, 255, 255, 0.18);
  }

  /* ─── Mobile ──────────────────────────────────── */

  @media (max-width: 768px) {
    .hero__mark {
      top: 18%;
      right: clamp(16px, 4vw, 32px);
      gap: 8px;
    }
    .hero__name { white-space: normal; }
    .hero__name { font-size: clamp(26px, 9vw, 40px); }
    .hero__sub  { font-size: 14px; }
  }
</style>
