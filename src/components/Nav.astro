</header>

<!-- Mobile drawer -->
<div class="nav__drawer" id="navDrawer" aria-hidden="true" role="dialog" aria-modal="true">
  <button class="nav__drawer-close" id="navClose" aria-label="Close menu">
    <span></span><span></span>
  </button>
  <nav class="nav__drawer-links" aria-label="Mobile navigation">
    <a href="/"           class="nav__drawer-link">Home</a>
    <a href="/retreats"   class="nav__drawer-link">Live Retreats</a>
    <a href="/mountains"  class="nav__drawer-link">Mountains</a>
    <a href="/programs"   class="nav__drawer-link">Online Programs</a>
    <a href="/mentorship" class="nav__drawer-link">Mentorship</a>
    <a href="/music"      class="nav__drawer-link">Music</a>
    <a href="/about"      class="nav__drawer-link">About</a>
    <a href="/connect?source=nav_drawer" class="nav__drawer-link nav__drawer-link--cta">Connect</a>
  </nav>
  <div class="nav__drawer-foot">
    <div class="nav__drawer-socials">
      <a href="https://t.me/yakovrajuna" class="nav__drawer-social" target="_blank" rel="noopener" aria-label="Telegram">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M21.198 2.433a2.242 2.242 0 0 0-1.022.215L3.29 9.865c-1.392.54-1.386 1.295-.253 1.629l4.47 1.395 10.35-6.528c.488-.298.937-.14.569.186L9.568 15.366l-.32 4.576c.471 0 .68-.217.938-.467l2.253-2.189 4.68 3.455c.862.476 1.482.23 1.696-.8l3.07-14.43c.313-1.253-.476-1.821-1.687-1.078z" fill="currentColor"/>
        </svg>
      </a>
      <a href="https://instagram.com/yakovrajuna" class="nav__drawer-social" target="_blank" rel="noopener" aria-label="Instagram">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5.5" stroke="currentColor" stroke-width="1.6"/>
          <circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.6"/>
          <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor"/>
        </svg>
      </a>
      <a href="https://youtube.com/@yakovrajuna" class="nav__drawer-social" target="_blank" rel="noopener" aria-label="YouTube">
        <svg width="20" height="18" viewBox="0 0 22 16" fill="none" aria-hidden="true">
          <rect x="0.8" y="0.8" width="20.4" height="14.4" rx="3.8" stroke="currentColor" stroke-width="1.6"/>
          <path d="M9 4.5l6 3.5-6 3.5V4.5z" fill="currentColor"/>
        </svg>
      </a>
    </div>
    <span class="t-label" style="opacity: 0.38;">by Yakov Rajuna</span>
  </div>
</div>
<div class="nav__overlay" id="navOverlay" aria-hidden="true"></div>

<script>
  const burger  = document.getElementById('navBurger')!;
  const close   = document.getElementById('navClose')!;
  const drawer  = document.getElementById('navDrawer')!;
  const overlay = document.getElementById('navOverlay')!;
  const nav     = document.getElementById('site-nav')!;

  function openMenu() {
    burger.setAttribute('aria-expanded', 'true');
    drawer.setAttribute('aria-hidden', 'false');
    overlay.setAttribute('aria-hidden', 'false');
    drawer.classList.add('nav__drawer--open');
    overlay.classList.add('nav__overlay--show');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    burger.setAttribute('aria-expanded', 'false');
    drawer.setAttribute('aria-hidden', 'true');
    overlay.setAttribute('aria-hidden', 'true');
    drawer.classList.remove('nav__drawer--open');
    overlay.classList.remove('nav__overlay--show');
    document.body.style.overflow = '';
  }

  burger.addEventListener('click', openMenu);
  close.addEventListener('click',  closeMenu);
  overlay.addEventListener('click', closeMenu);

  window.addEventListener('scroll', () => {
    nav.classList.toggle('nav--scrolled', window.scrollY > 60);
  }, { passive: true });
</script>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding-block: 26px;
    border-bottom: 1px solid transparent;
    transition:
      background    700ms var(--ease),
      border-color  700ms var(--ease),
      padding-block 600ms var(--ease),
      backdrop-filter 700ms var(--ease);
  }

  .nav--scrolled {
    background: rgba(250, 247, 240, 0.90);
    backdrop-filter: blur(18px) saturate(1.4);
    -webkit-backdrop-filter: blur(18px) saturate(1.4);
    border-color: rgba(166, 124, 77, 0.12);
    padding-block: 16px;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-5);
  }

  /* Wordmark */
  .nav__wordmark {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 18px;
    letter-spacing: -0.01em;
    color: var(--earth);
    line-height: 1;
    font-optical-sizing: auto;
    transition: color 300ms ease;
    white-space: nowrap;
  }
  .nav__logo:hover .nav__wordmark { color: var(--honey); }

  /* Nav links */
  .nav__links {
    display: flex;
    align-items: center;
    gap: clamp(10px, 1.8vw, 30px);
    flex: 1;
    justify-content: center;
  }

  .nav__link {
    font-family: var(--mark);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--fg-soft);
    transition: color 280ms ease;
    padding: 4px 0;
    white-space: nowrap;
  }
  .nav__link:hover { color: var(--earth); }

  .nav__link--connect {
    color: var(--honey);
    border-bottom: 1px solid rgba(166, 124, 77, 0.30);
    padding-bottom: 2px;
    transition: color 280ms ease, border-color 280ms ease;
  }
  .nav__link--connect:hover {
    color: var(--ember);
    border-color: var(--ember);
  }

  /* Right cluster: socials + connect + burger */
  .nav__right {
    display: flex;
    align-items: center;
    gap: clamp(10px, 1.6vw, 24px);
  }

  /* Social icons */
  .nav__socials {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .nav__social {
    color: var(--fg-soft);
    opacity: 0.62;
    transition: opacity 260ms ease, color 260ms ease;
    display: flex;
    align-items: center;
  }
  .nav__social:hover {
    opacity: 1;
    color: var(--earth);
  }

  /* Burger */
  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none; border: none;
    padding: 4px; cursor: pointer;
  }
  .nav__burger span {
    display: block;
    width: 24px; height: 1px;
    background: var(--earth);
    transform-origin: left center;
    transition: transform 400ms var(--ease), opacity 300ms;
  }
  .nav__burger span:last-child { transform: scaleX(0.667); }
  .nav__burger:hover span:last-child { transform: scaleX(1); }

  /* Drawer */
  .nav__drawer {
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: min(400px, 90vw);
    background: var(--bone);
    z-index: 110;
    padding: var(--s-9) var(--s-7) var(--s-7);
    display: flex;
    flex-direction: column;
    justify-content: center;
    transform: translateX(100%);
    transition: transform 550ms var(--ease);
    border-left: 1px solid var(--rule);
  }
  .nav__drawer--open { transform: translateX(0); }

  .nav__drawer-close {
    position: absolute;
    top: 28px; right: 28px;
    width: 40px; height: 40px;
    background: none; border: none;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
  }
  .nav__drawer-close span {
    display: block;
    width: 20px; height: 1px;
    background: var(--earth);
    position: absolute;
  }
  .nav__drawer-close span:first-child { transform: rotate(45deg); }
  .nav__drawer-close span:last-child  { transform: rotate(-45deg); }

  .nav__drawer-links {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }

  .nav__drawer-link {
    font-family: var(--serif);
    font-size: clamp(26px, 5vw, 38px);
    font-weight: 400;
    letter-spacing: -0.015em;
    color: var(--earth);
    line-height: 1.2;
    font-optical-sizing: auto;
    transition: color 240ms ease, transform 280ms var(--ease);
  }
  .nav__drawer-link:hover { color: var(--honey); transform: translateX(var(--s-3)); }

  .nav__drawer-link--cta {
    color: var(--honey);
    margin-top: var(--s-3);
    font-size: clamp(18px, 3.5vw, 26px);
    letter-spacing: 0.01em;
  }
  .nav__drawer-link--cta:hover { color: var(--ember); padding-left: 0; }

  .nav__drawer-foot {
    margin-top: auto;
    padding-top: var(--s-7);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__drawer-socials {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .nav__drawer-social {
    color: var(--earth);
    opacity: 0.45;
    display: flex;
    align-items: center;
    transition: opacity 240ms ease;
  }
  .nav__drawer-social:hover { opacity: 0.85; }

  .nav__overlay {
    position: fixed; inset: 0;
    background: rgba(46, 42, 36, 0.28);
    z-index: 105;
    opacity: 0; pointer-events: none;
    transition: opacity 400ms ease;
    backdrop-filter: blur(3px);
  }
  .nav__overlay--show { opacity: 1; pointer-events: auto; }

  @media (max-width: 1000px) {
    .nav__links  { display: none; }
    .nav__burger { display: flex; }
    .nav__socials { display: none; }
    .nav__link--connect { display: none; }
  }
</style>
