          </svg>
        </a>
        <a href="https://instagram.com/yakovrajuna" class="nav__social" aria-label="Instagram" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5.5" stroke="currentColor" stroke-width="1.6"/>
            <circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.6"/>
            <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor"/>
          </svg>
        </a>
        <a href="https://youtube.com/@yakovrajuna" class="nav__social" aria-label="YouTube" target="_blank" rel="noopener">
