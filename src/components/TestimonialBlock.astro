---
export interface Props {
  quote: string;
  author: string;
  detail?: string;
  dark?: boolean;
}
const { quote, author, detail, dark = false } = Astro.props;
---

<div class={`testimonial ${dark ? 'testimonial--dark' : ''}`}>
  <p class="testimonial__quote">{quote}</p>
  <div class="testimonial__byline">
    <span class="testimonial__dash" aria-hidden="true">—</span>
    <span class="testimonial__author">{author}</span>
    {detail && <span class="testimonial__detail">{detail}</span>}
  </div>
</div>

<style>
  .testimonial {
    border-left: 1px solid var(--rule);
    padding-left: var(--s-6);
    max-width: 54ch;
  }

  .testimonial__quote {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(16px, 1.5vw, 20px);
    line-height: 1.6;
    color: var(--fg-soft);
    margin: 0 0 var(--s-4);
    letter-spacing: 0.005em;
    font-optical-sizing: auto;
  }

  .testimonial__byline {
    display: flex;
    align-items: center;
    gap: var(--s-3);
  }

  .testimonial__dash {
    font-family: var(--serif);
    color: var(--honey);
    font-size: 14px;
    flex-shrink: 0;
  }

  .testimonial__author {
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--earth);
  }

  .testimonial__detail {
    font-family: var(--mark);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-mute);
  }
  .testimonial__detail::before { content: "· "; }

  /* Dark variant — for chapters on dark backgrounds */
  .testimonial--dark {
    border-color: var(--rule-d);
  }
  .testimonial--dark .testimonial__quote {
    color: rgba(250, 247, 240, 0.60);
  }
  .testimonial--dark .testimonial__author {
    color: rgba(250, 247, 240, 0.80);
  }
  .testimonial--dark .testimonial__detail {
    color: rgba(250, 247, 240, 0.40);
  }
</style>
